/*/{Protheus.doc} GetCodSegment
    Retorna codigo do seguimento do cliente
    @type  Function
    @author Lucas Silva Vieira
    @since 01/02/2024
    @version 1.0
    @return nCodSegment, numeric, codigo da cidade
/*/
user function GetCodSegment(cSegment) as numeric
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath            := "/v1/segments"                                as character
	local cParam 		   := ""                                            as character
	local cStatus          := ""                                            as character
	local cBodyStr         := ""                                            as character
	local cDesc 		   := ""											as character
	local nCodSegment	   := 0                                             as numeric

	dbSelectArea("ZZZ")
	cDesc := Posicione("ZZZ", 1, xFilial("ZZZ")+"FAT000005"+Right(cSegment,3), "ZZZ_RETORN")

	cParam := "?name="+Alltrim(cDesc)

	oRest:setPath(cPath+cParam)

	if (oRest:get(aHeader))
		cStatus  := oRest:getHttpCode()
		cBodyStr := oRest:getResult()
		oReturn := JsonObject():new()
		cError := oReturn:fromJson(cBodyStr)

		if cStatus == SUCCESS
			if (oReturn:hasProperty('message'))
				if oReturn['message'] == "OK" .AND. len(oReturn['data']) > 0
					nCodSegment := oReturn['data'][01]['id']
				endif
			endif
		else
			FWAlertError("ERROR: "+cStatus)
			lToken := .F.
		endif
	endif

return nCodSegment

/*/{Protheus.doc} GetCodCnae
    Retorna codigo do cnae do cliente
    @type  Function
    @author Lucas Silva Vieira
    @since 01/02/2024
    @version 1.0
    @return nCodSegment, numeric, codigo da cidade
/*/
user function GetCodCnae(cCnae) as numeric
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath            := "/v1/cnaes"                                   as character
	local cParam 		   := ""                                            as character
	local cStatus          := ""                                            as character
	local cBodyStr         := ""                                            as character
	local nCodCnae	       := 0                                             as numeric

	cParam := "?code="+substr(cCnae,0,2)+"."+substr(cCnae,3,2)+"-"+substr(cCnae,6,1)+"-"+substr(cCnae,8,2)

	oRest:setPath(cPath+cParam)

	if (oRest:get(aHeader))
		cStatus  := oRest:getHttpCode()
		cBodyStr := oRest:getResult()
		oReturn := JsonObject():new()
		cError := oReturn:fromJson(cBodyStr)

		if cStatus == SUCCESS
			if (oReturn:hasProperty('message'))
				if oReturn['message'] == "OK" .AND. len(oReturn['data']) > 0
					nCodCnae := oReturn['data'][01]['id']
				endif
			endif
		else
			FWAlertError("ERROR: "+cStatus)
			lToken := .F.
		endif
	endif

return nCodCnae

user function SincPropesct()
	Local cTemp			:= ""	As Character
	Local cQuery 		:= ""   As Character
	//Local codPropesct	:= ""	As Character
	//Local Lojapropesct  := ""	As Character
	//Local cType 		:= "F"  As Character
	Local oStatement 	:= nil  As Object

	cQuery := "SELECT  SA1.A1_COD, SA1.A1_LOJA " +;
		"FROM " + RetSqlName("SUA") + "SUA" +;
		"INNER JOIN " + RetSqlName("SA1") + " SA1 ON SA1.A1_COD = SUA.UA_CLIENTE AND SA1.A1_LOJA = SUA.UA_LOJA AND SA1.D_E_L_E_T_ = '' " +;
		"WHERE SUA.D_E_L_E_T_ = '' " +;
		"AND UA_PROSPEC = ? " +;
		"GROUP BY SA1.A1_COD, SA1.A1_LOJA "

	oStatement := FWPreparedStatement():New()
	oStatement:SetQuery(cQuery)
	oStatement:SetString(1,xFilial("ZZ1"))
	oStatement:SetString(2,__EmpAbast)

	cQuery := oStatement:GetFixQuery()
	cTemp := mpsysopenquery(cQuery)
	cTimeStamp 	:= substr(Alltrim((cTemp)->MAX_TIME),1,10)+substr(Alltrim((cTemp)->MAX_TIME),12,5)

	if empty(cTimeStamp)
		cTimeStamp := "2023-10-0100:00"
	endif
return

user function SincCodCity()
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath            := "/v1/cities"                                  as character
	local oReturn 		   := JsonObject():new()							as object
	local cStatus          := ""                                            as character
	local cBodyStr         := ""                                            as character
	local cView 		   := ""											as character
	local cError 		   := ""											as character

	cView := getCity()
	
	dbSelectArea('CC2')
	while (cView)->(!Eof())
		oRest:setPath(cPath+"?name="+escape(allTrim((cView)->CC2_MUN))+"&uf="+allTrim((cView)->CC2_EST))
		if (oRest:get(aHeader))
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			oReturn:fromJson(cBodyStr)
			if cStatus == SUCCESS
				if (oReturn:hasProperty('message'))
					if oReturn['message'] == "OK" .AND. oReturn:hasProperty('data') .AND. len(oReturn['data']) > 0
						CC2->(dbSetOrder(1)) //CC2_FILIAL+CC2_EST+CC2_CODMUN 	
						if CC2->(dbSeek(FwXFilial('CC2')+(cView)->CC2_EST+(cView)->CC2_CODMUN))
							if empty(CC2->CC2_IDCITY)
								RecLock('CC2', .F.)
								CC2->CC2_IDCITY := cValToChar(oReturn['data'][1]['id'])
								CC2->(msUnlock())
							endIf	
						endIf
					endif
				endif
			endif
		else
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			cError += BASE_URL+cPath+"?name="+alltrim(lower((cView)->CC2_MUN))+"&uf="+alltrim(lower((cView)->CC2_EST)) + CRLF
		endif
		(cView)->(dbSkip())
	endDo
	if !empty(cError)
		ShowLog(cError)
	endIf
return 

static function getCity()
	local cQuery 		:= ""				as character
	local oStatement 	:= Nil				as object
	local cView			:= ""				as character

	cQuery := "SELECT CC2_EST, CC2_MUN, CC2_CODMUN " + CRLF
	cQuery += "FROM " + RetSqlName('CC2') + CRLF
	cQuery += "WHERE D_E_L_E_T_ = ' '  " + CRLF

	oStatement := FWPreparedStatement():New(cQuery)
	cQuery := oStatement:GetFixQuery()
	cView  := mpsysopenquery(cQuery)

	freeObj(oStatement)

return cView
