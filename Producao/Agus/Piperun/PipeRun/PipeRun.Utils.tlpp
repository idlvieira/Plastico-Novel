#include 'tlpp-core.th'

namespace PipeRun.utils

#define BASE_URL    SUPERGETMV("ES_PORTAL", .F., "https://api.pipe.run") // url base
#define TOKEN       "c53697da076fbc5928803181d19d8444" //token
#define SUCCESS     "200"
#define CRLF        chr(13) + chr(10)
#define MAX_ERROR_SIZE  100
#define MAX_DET_ERROR_SIZE  200

/*/{Protheus.doc} getRestObject
    Retorna um objeto FWRest genérico para integraçăo com PipeRun
    @type  Function
    @author Lucas Silva Vieira
    @since 05/01/2024
    @version 1.0
    @return oRest, object, instância da classe FWRest
/*/
user function getRestObject() as object
	local oRest as object // instância da classe FWRest

	oRest := FWRest():new(BASE_URL)
	oRest:setChkStatus(.T.)

return oRest

/*/{Protheus.doc} getBaseHeader
    Retorna um array com headers base para requisiçőes
    @type  Function
    @author Lucas Silva Vieira
    @since 05/01/2024
    @version 1.0
    @return aHeader, array, header base
/*/
user function getBaseHeader() as array
	local aHeader as array // header base

	aHeader := {}
	aAdd(aHeader, "Accept: application/json")
	aAdd(aHeader, "token: " + TOKEN )
	aAdd(aHeader, "Content-Type: application/json; charset=utf-8")

return aHeader

/*/{Protheus.doc} ValidToken
    Retorna token
    @type  Function
    @author Lucas Silva Vieira
    @since 05/01/2024
    @version 1.0
    @return lToken, logical, token valido?
/*/
user function ValidToken()
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath            := "/v1/auth"                                    as character
	local cStatus          := ""                                            as character
	local cBodyStr         := ""                                            as character
	local cError           := ""                                            as character
	local oReturn          := Nil                                           as object
	local lToken           := .T.                                           as logical

	oRest:setPath(cPath)

	if (oRest:get(aHeader))

		cStatus  := oRest:getHttpCode()
		cBodyStr := oRest:getResult()
		oReturn := JsonObject():new()
		cError := oReturn:fromJson(cBodyStr)

		if cStatus == SUCCESS
			if (oReturn:hasProperty('message'))
				if oReturn['message'] == "OK"
					lToken := .F.
				endif
			endif
		else
			FWAlertError("ERROR: "+cStatus)
			lToken := .F.
		endif
	else
		FWAlertError("ERROR: Năo possivel estabelecer a conexăo!" + CRLF + "Verifique os parâmetros de conexăo.")
		lToken := .F.
	endif

return lToken

/*/{Protheus.doc} GetCodCity
    Retorna codigo da cidade
    @type  Function
    @author Lucas Silva Vieira
    @since 05/01/2024
    @version 1.0
	@param cUF,   character, sigla do estado
	@param cCity, character, Nome da cidade
    @return nCodCity, numeric, codigo da cidade
/*/
user function GetCodCity(cUF, cCity) as numeric
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath            := "/v1/cities"                                  as character
	local cParam 		   := ""                                            as character
	local cStatus          := ""                                            as character
	local cBodyStr         := ""                                            as character
	local nCodCity		   := 0                                             as numeric

	cParam := "?name="+cCity+"&uf="+cUF

	oRest:setPath(cPath+cParam)

	if (oRest:get(aHeader))
		cStatus  := oRest:getHttpCode()
		cBodyStr := oRest:getResult()
		oReturn := JsonObject():new()
		cError := oReturn:fromJson(cBodyStr)

		if cStatus == SUCCESS
			if (oReturn:hasProperty('message'))
				if oReturn['message'] == "OK" .AND. oReturn:hasProperty('data') .AND. len(oReturn['data']) > 0
					nCodCity := oReturn['data'][01]['id']
				else
					conOut("ERROR: Cidade Năo Localizada")
				endif
			endif
		else
			conOut("ERROR: "+cStatus)
		endif
	endif

return nCodCity

user function GetCompany(cCNPJ)
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath            := "/v1/companies"                               as character
	local cParam 		   := ""                                            as character
	local cStatus          := ""                                            as character
	local cBodyStr         := ""                                            as character
	local nCompany 		   := 0 											as numeric

	cParam := "?cnpj="+cCNPJ

	oRest:setPath(cPath+cParam)

	if (oRest:get(aHeader))
		cStatus  := oRest:getHttpCode()
		cBodyStr := oRest:getResult()
		oReturn := JsonObject():new()
		cError := oReturn:fromJson(cBodyStr)

		if cStatus == SUCCESS
			if (oReturn:hasProperty('message'))
				if oReturn['message'] == "OK" .AND. oReturn:hasProperty('data') .AND. len(oReturn['data']) > 0
					nCompany := oReturn['data'][01]['id']
				else
					conOut("ERROR: CNPJ năo localizado!")
				endif
			endif
		else
			conOut("ERROR: "+cStatus)
		endif
	endif
return nCompany

