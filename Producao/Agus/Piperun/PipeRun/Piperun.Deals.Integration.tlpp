/*/{Protheus.doc} User Function DeđalsIntegration
    integraçăo de oportinidades
    @type Function
    @author Lucas Silva Vieira | Agus Consultoria
    @since 06/05/2024
    @version 2210
    @seek https://vendas.developers.pipe.run/reference/adicionar-oportunidade
/*/
User Function DealsIntegration()
	PipeRun.Deals.PostDeals()
Return

/*/{Protheus.doc} User Function PostDeals
    integraçăo de oportinidades
    @type Function
    @author Lucas Silva Vieira
    @since 06/05/2024
    @version 2210
    @seek https://vendas.developers.pipe.run/reference/adicionar-oportunidade
/*/
static  function PostDeals()
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath      	   := "/v1/deals"           					    as character
	local jPost            := Nil                                           as json
	local lSend			   := .F.											as logical
	local nUser            := 0                                             as numeric
	local nContact         := 0                                             as numeric
	local nCompany         := 0                                             as numeric
	local nPipeline   	   := 0 											as numeric
	local nStage      	   := 0 											as numeric
	local nTemp       	   := 0 											as numeric
	local nOrigin     	   := 0 											as numeric
	local nAmount     	   := 0 											as numeric
	local nIndex           := 0											    as numeric
	local cDTcreate   	   := "" 											as character
	local cNum        	   := "" 											as character
	local cName			   := ""										    as character
	local cDtPrev		   := ""											as character
	local nPosDesc		   := GDFieldPos("UB_DESCRI")						as numeric
	local nPosProd		   := GDFieldPos("UB_PRODUTO")						as numeric
	local nPosQuant		   := GDFieldPos("UB_QUANT")						as numeric
	local nPostValNet	   := GDFieldPos("UB_ZVLNET")						as numeric
	local nPosTES		   := GDFieldPos("UB_TES")							as numeric
	local nAdd 			   := 0												as numeric
	local nPercet 		   := 0												as numeric

	BEGIN TRANSACTION

		nUser       	:= val(Posicione("SA3", 1, FwXFilial("SA3")+M->UA_VEND, "A3_PIPERUN"))
		nContact    	:= val(Posicione("SU5", 1, FwXFilial("SU5")+M->UA_CODCONT, "U5_PIPERUN"))
		nPipeline 		:= val(M->UA_XFUNIL)
		nStage			:= val(M->UA_XSTAGE)
		nTemp 			:= val(M->UA_XTEMP)
		nOrigin			:= val(M->UA_XORIGEM)
		cNum 			:= alltrim(M->UA_NUM)
		nAmount 		:= TotalAmount(aCols)
		cDTcreate		:= M->UA_TIMESTA
		nPercet 		:= val(M->UA_XPROBAB)
		cDtPrev			:= M->UA_XDTFECH

		if empty(cDtPrev)
			cDtPrev	:= 	substr(cValTochar(lastDay(date())),7,4)+"-"+substr(cValTochar(lastDay(date())),4,2)+"-"+substr(cValTochar(lastDay(date())),1,2)
		else
			cDtPrev := substr(cValTochar(cDtPrev),7,4)+"-"+substr(cValTochar(cDtPrev),4,2)+"-"+substr(cValTochar(cDtPrev),1,2)
		endif

		if lprospect
			nCompany    := val(Posicione('SUS', 1, FWxFilial('SUS')+M->(UA_CLIENTE + M->UA_LOJA), 'US_PIPERUN'))
			cName		:= Posicione('SUS', 1, FWxFilial('SUS')+M->(UA_CLIENTE + M->UA_LOJA), 'US_NOME')
		else
			nCompany    := val(Posicione("SA1", 1, FwXFilial("SA1")+M->UA_CLIENTE + M->UA_LOJA, "A1_PIPERUN"))
			cName		:= Posicione("SA1", 1, FwXFilial("SA1")+M->UA_CLIENTE + M->UA_LOJA, "A1_NOME")
		endif

		cTitle 			:= allTrim(cNum) +" - "+ allTrim(cName)+ " | " + alltrim(FwFilialName(cEmpAnt,cFilAnt,1))

		jPost := JsonObject():new()

		jPost["pipeline_id"			]   := nPipeline                //ID do funil da oportunidade.
		jPost["stage_id"			]   := nStage                   //ID da etapa do funil da oportunidade.
		jPost["title"				]   := cTitle            		//Título da oportunidade.
		jPost["temperature"			]   := nTemp                    //Temperatura da oportunidade, sendo: 1: muito quente; 2: quente; 3: morna e 4: fria.
		jPost["origin_id"			]   := nOrigin                  //ID da origem da oportunidade.
		jPost["owner_id"			]   := nUser                    //ID do usuário responsável pela oportunidade.
		jPost["person_id"			]   := nContact                 //ID da pessoa de contato da oportunidade.
		jPost["company_id"			]   := nCompany                 //ID da empresa da oportunidade.
		jPost["created_at"			]	:= cDTcreate    			//Data de criaçăo da oportunidade.
		jPost["status"				]   := 0                        //Status da oportunidade: 0: aberta, 1: ganha, 3: perdida.
		jPost["value"				]   := nAmount                  //Valor de produtos e serviços (P&S) da oportunidade.
		jPost['probability'       	] 	:= nPercet
		jPost['probably_closed_at'	] 	:= cDtPrev

		jPost["tags"] := {}
		aAdd(jPost["tags"		], JsonObject():new())

		if nTemp == 4
			jPost["tags"			][01]["id"          ] := val(__cTagFria)
		elseif nTemp == 3
			jPost["tags"			][01]["id"          ] := val(__cTagMorna)
		elseif nTemp == 1 .OR. nTemp == 2
			jPost["tags"			][01]["id"          ] := val(__cTagQuente)
		endif

		jPost["custom_fields"   ]   := {}

		aAdd(jPost["custom_fields"   ], JsonObject():new())
		jPost["custom_fields"][01]["id"          ] := val(__cFildlocal)
		jPost["custom_fields"][01]["value"       ] := alltrim(FwFilialName(cEmpAnt,cFilAnt,2))

		aAdd(jPost["custom_fields"   ], JsonObject():new())
		jPost["custom_fields"][02]["id"          ] := val(__cNumOrca)
		jPost["custom_fields"][02]["value"       ] := alltrim(cNum)

		dbSelectArea("SF4")
		SF4->(dbSetOrder(01)) //F4_FILIAL+F4_CODIGO
		for nIndex := 01 to len(aCols)
			lSend := Posicione("SF4",1,FwXFilial("SF4") + alltrim(aCols[nIndex][nPosTES]),"F4_PIPERUN")
			if lSend
				aAdd(jPost["custom_fields"   ], JsonObject():new())
				nAdd := len(jPost["custom_fields"   ])

				//produto
				cField1 := __cFildProducts + cValToChar(nIndex)
				jPost["custom_fields"][nAdd]["id"          ] := val(&(cField1))
				jPost["custom_fields"][nAdd]["value"       ] := alltrim(aCols[nIndex][nPosProd]) + " - " + alltrim(aCols[nIndex][nPosDesc])

				aAdd(jPost["custom_fields"                 ], JsonObject():new())
				nAdd := len(jPost["custom_fields"          ])

				//quantidade
				cField2 := __cFildQuantity + cValToChar(nIndex)
				jPost["custom_fields"][nAdd]["id"          ] := val(&(cField2))
				jPost["custom_fields"][nAdd]["value"       ] := cValToChar(aCols[nIndex][nPosQuant])

				aAdd(jPost["custom_fields"   			  ], JsonObject():new())
				nAdd := len(jPost["custom_fields"         ])

				//valor unitario
				cField3 := __cFildValue + cValToChar(nIndex)
				jPost["custom_fields"][nAdd]["id"          ] := val(&(cField3))
				jPost["custom_fields"][nAdd]["value"       ] := cValToChar(aCols[nIndex][nPostValNet])

				if len(aCols) < nIndex
					aAdd(jPost["custom_fields"   			   ], JsonObject():new())
					nAdd := len(jPost["custom_fields"          ])
					nAdd++
				endif
			endif
		next nIndex

		oRest:setPath(cPath)

		if lSend
			if nUser <=0
				FwAlertInfo("Cliente / Prospect năo vinculo ao Piperun!")
			elseif nContact <= 0
				FwAlertInfo("Contato năo vinulado ao Piperun!")
			elseif nPipeline <= 0 .or. nStage <=0
				FwAlertInfo("Funil ou Etapa năo vinculada ao Piperun!")
			endIf
			if nUser > 0 .and. nContact  > 0 .and. nPipeline > 0 .and. nStage > 0
				oRest:setPostParams(jPost:toJson())
			endif
		endIf

		if (oRest:post(aHeader))
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			oResponse := JsonObject():new()
			oResponse:fromJson(cBodyStr)
			if (oResponse:hasProperty('data'))
				SUA->(dbSetOrder(01)) //UA_FILIAL + UA_NUM
				if SUA->(dbSeek(SUA->UA_FILIAL + SUA->UA_NUM))
					if RecLock("SUA", .F.)
						SUA->UA_XINTREG := "S"
						SUA->UA_PIPERUN := cValToChar(oResponse['data']['id'])
						SUA->UA_XSTATUS := "0"
						SUA->UA_XJSON := jPost:toJson()
						SUA->UA_XLOGINT := "Log de integraçăo: " + CRLF + ;
							"Açăo executada: Inclusăo " + CRLF + ;
							"Retorno: Sucesso na inclusăo " + CRLF + ;
							"Data : " + Dtoc(Date()) + CRLF +;
							"Hora: " + time() + CRLF + ;
							"Status: " + cStatus + CRLF + ;
							"Retorno: " + cBodyStr + CRLF
						SUA->(msUnlock())
					endif
				endif
			endif
		else
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			SUA->(dbSetOrder(01)) //UA_FILIAL + UA_NUM
			if SUA->(dbSeek(SUA->UA_FILIAL + SUA->UA_NUM))
				if RecLock("SUA", .F.)
					SUA->UA_XINTREG := "N"
					SUA->UA_PIPERUN := ""
					SUA->UA_XJSON := jPost:toJson()
					SUA->UA_XLOGINT := "Log de integraçăo: " + CRLF + ;
						"Açăo executada: Inclusăo " + CRLF + ;
						"Retorno: Erro na inclusăo: " + CRLF + ;
						"Data : " + Dtoc(Date()) + CRLF +;
						"Hora: " + time() + CRLF + ;
						"Status: " + cStatus + CRLF + ;
						"Retorno: " + cBodyStr + CRLF
					SUA->(msUnlock())
				endif
			endif
		endif

	END TRANSACTION

return

static function TotalAmount(aDados)
	local nAmount 	:= 0 							as numeric
	local nIndex  	:= 0 							as numeric
	local nPosVal 	:= GDFieldPos("UB_ZVLNET ")		as numeric
	local nPosQuant := GDFieldPos("UB_QUANT")		as numeric
	local nPosTES	:= GDFieldPos("UB_TES")			as numeric
	local lSend		:= .F.							as logical

	for nIndex := 01 to len(aDados)
		lSend := Posicione("SF4",1,FwXFilial("SF4") + alltrim(aDados[nIndex][nPosTES]),"F4_PIPERUN")
		if lSend
			if aDados[nIndex][nPosVal] > 0 .and. aDados[nIndex][nPosQuant] > 0
				nAmount += (aDados[nIndex][nPosQuant] * aDados[nIndex][nPosVal])
			endIf
		endif
	next nIndex
return nAmount

user function UpdateStages(cPiperun, cStage, cPipelineId, cNum, cDate, cProbability) as logical
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath      	   := "/v1/deals/"           						as character
	local oResponse        := nil											as object
	local cStatus    	   := ""                                            as character
	local jPut             := JsonObject():new()                            as json
	local nStatus		   := 0												as numeric
	local lStatus		   := .F.											as logical

	if (!empty(cPiperun))
		oRest:setPath(cPath + Alltrim(cPiperun))

		jPut['pipeline_id'		 ]  := val(cPipelineId)
		jPut['stage_id'			 ] 	:= val(cStage)
		jPut['probability'       ] 	:= val(cProbability)
		jPut['probably_closed_at'] 	:= cDate

		if (oRest:put(aHeader, jPut:toJson()))
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			oResponse := JsonObject():new()
			oResponse:fromJson(cBodyStr)
			lStatus := .T.
			SUA->(dbSetOrder(01)) //UA_FILIAL + UA_NUM
			if RecLock("SUA", .F.)
				SUA->UA_XINTREG := "S"
				SUA->UA_XSTAGE  := cStage
				SUA->UA_XJSON := jPut:toJson()
				SUA->UA_XSTATUS := cValToChar(nStatus)
				SUA->UA_XPROBAB	:= cProbability
				SUA->UA_XDTFECH := stod(substr(cValTochar(cDate),9,2)+"/"+substr(cValTochar(cDate),6,2)+"/"+substr(cValTochar(cDate),1,4))
				SUA->UA_XLOGINT := "Log de integraçăo: " + CRLF + ;
					"Açăo executada: Movimentaçăo de Card " + CRLF + ;
					"Retorno: Sucesso na atualizaçăo: " + CRLF + ;
					"Data : " + Dtoc(Date()) + CRLF +;
					"Hora: " + time() + CRLF + ;
					"Status: " + cStatus + CRLF + ;
					"Retorno: " + cBodyStr + CRLF
				SUA->(msUnlock())
			endif
		else
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			lStatus := .F.
			SUA->(dbSetOrder(01)) //UA_FILIAL + UA_NUM
			if RecLock("SUA", .F.)
				SUA->UA_XINTREG := "S"
				SUA->UA_XSTAGE  := cStage
				SUA->UA_XJSON := jPut:toJson()
				SUA->UA_XSTATUS := cValToChar(nStatus)
				SUA->UA_XLOGINT := "Log de integraçăo: " + CRLF + ;
					"Açăo executada: Movimentaçăo de Card " + CRLF + ;
					"Retorno: Erro na atualizaçăo: " + CRLF + ;
					"Data : " + Dtoc(Date()) + CRLF +;
					"Hora: " + time() + CRLF + ;
					"Status: " + cStatus + CRLF + ;
					"Retorno: " + cBodyStr + CRLF
				SUA->(msUnlock())
			endif
			FwAlertInfo(cBodyStr, "Năo Foi possivel atualizar o status verifique a regra do funil.")
		endIf
	endif
return lStatus

user function DealsWins(cPipeRun, nStatus) as logical
	local oRest             := PipeRun.utils.u_getRestObject()              as object
	local aHeader           := PipeRun.utils.u_getBaseHeader()              as array
	local cPath      	    := "/v1/deals/"           						as character
	local oResponse         := nil											as object
	local cStatus    	    := ""                                           as character
	local jPut              := JsonObject():new()                           as json
	local lSuccess 			:= .T. 											as logical
	local cDate 			:= dtos(Date())									as character
	local nValid			:= 344900										as numeric


	if (!empty(cPiperun))
		oRest:setPath(cPath + Alltrim(cPiperun))

		jPut["custom_fields"   ]   := {}

		aAdd(jPut["custom_fields"   ], JsonObject():new())
		jPut["custom_fields"][01]["id"          ] := nValid
		jPut["custom_fields"][01]["value"       ] := "Sim"

		if (oRest:put(aHeader, jPut:toJson()))
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			oResponse := JsonObject():new()
			oResponse:fromJson(cBodyStr)
			lSuccess := .T.
		else
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			lSuccess := .F.
		endIf

		if lSuccess

			jPut['status']		:= nStatus
			jPut['closed_at']	:= substr(cDate,1,4)+"-"+substr(cDate,5,2)+"-"+substr(cDate,7,2)

			if (oRest:put(aHeader, jPut:toJson()))
				cStatus  := oRest:getHttpCode()
				cBodyStr := oRest:getResult()
				oResponse := JsonObject():new()
				oResponse:fromJson(cBodyStr)
				lSuccess := .T.
			else
				cStatus  := oRest:getHttpCode()
				cBodyStr := oRest:getResult()
				FwAlertInfo(cBodyStr,"Năo foi possivel dar ganho na oportunidade, verifique a regra do funil!")
				lSuccess := .F.
			endIf
		else
			FwAlertInfo("Năo foi possivel dar ganho na oportunidade, verifique a regra do funil!")
		endif
	endif
return lSuccess

user function DealsRequested(cPipeRun, cNumPed, cPipeline, cStage) as logical
	local oRest             := PipeRun.utils.u_getRestObject()              as object
	local aHeader           := PipeRun.utils.u_getBaseHeader()              as array
	local cPath      	    := "/v1/deals/"           						as character
	local oResponse         := nil											as object
	local cStatus    	    := ""                                           as character
	local jPut              := JsonObject():new()                           as json
	local nAdd				:= 01											as numeric
	local nOrder 			:= 0											as numeric

	if (!empty(cPiperun))
		oRest:setPath(cPath + Alltrim(cPiperun))

		nOrder := stageOrder(cPipeline)

		jPut['stage_id'] 						:= nOrder //ID da etapa do funil da oportunidade.
		jPut['started_in_stage_id']				:= val(cStage) //ID da etapa onde a oportunidade foi gerada.

		jPut["custom_fields"]   				:= {}
		aAdd(jPut["custom_fields"], JsonObject():new())

		jPut["custom_fields"][nAdd]["id"] 		:= val(__cNumPedido)
		jPut["custom_fields"][nAdd]["value" ] 	:= cNumPed

		if (oRest:put(aHeader, jPut:toJson()))
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			oResponse := JsonObject():new()
			oResponse:fromJson(cBodyStr)

			SUA->(dbSetOrder(13)) //UA_FILIAL + UA_PIPERUN
			if SUA->(dbSeek(FWxFilial("SUA")+cPipeRun))
				if SUA->(RecLock("SUA", .F.))
					SUA->UA_XSTAGE := cValToChar(nOrder)
					SUA->(MsUnLock())
				endif
			endif

		else
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
		endIf
	endif
return

user function DealsLoss(cPipeRun, cMotivo, cJustic)
	local oRest             := PipeRun.utils.u_getRestObject()              as object
	local aHeader           := PipeRun.utils.u_getBaseHeader()              as array
	local cPath      	    := "/v1/deals/"           						as character
	local oResponse         := nil											as object
	local cStatus    	    := ""                                           as character
	local jPut              := JsonObject():new()                           as json
	local cDate 			:= dtos(Date())									as character
	local nAdd				:= 1											as numeric

	if (!empty(cPiperun))
		oRest:setPath(cPath + Alltrim(cPiperun))

		jPut['status']			:= 3
		jPut['lost_reason_id']	:= val(cMotivo)
		jPut['closed_at']		:= substr(cDate,1,4)+"-"+substr(cDate,5,2)+"-"+substr(cDate,7,2)

		jPut["custom_fields"]   := {}
		aAdd(jPut["custom_fields"], JsonObject():new())

		jPut["custom_fields"][nAdd]["id"] := val(__cFilMtPerda)
		jPut["custom_fields"][nAdd]["value" ] := alltrim(cJustic)


		if (oRest:put(aHeader, jPut:toJson()))
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			oResponse := JsonObject():new()
			oResponse:fromJson(cBodyStr)
		else
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
		endIf
	endif
return

user function DealsPut(cPiperun)
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath      	   := "/v1/deals/"           						as character
	local oResponse        := nil											as object
	local cStatus    	   := ""                                            as character
	local jPut             := JsonObject():new()                            as json
	local nIndex 		   := 0 											as numeric
	local nAdd			   := 0												as numeric
	local lSend			   := .F.											as logical
	local nStage		   := val(M->UA_XSTAGE)								as numeric
	local nTemp 		   := val(M->UA_XTEMP)								as numeric
	local nStatus		   := val(M->UA_XSTATUS)							as numeric
	local nPipeline		   := val(M->UA_XFUNIL)								as numeric
	local nPosTES		   := GDFieldPos("UB_TES")							as numeric
	local nPosProd		   := GDFieldPos("UB_PRODUTO")						as numeric
	local nPosQuant		   := GDFieldPos("UB_QUANT")						as numeric
	local nPostValNet	   := GDFieldPos("UB_ZVLNET ")						as numeric	///UB_ZVLNET
	local nAmount 		   := TotalAmount(aCols)							as numeric
	local nCompany		   := 0												as numeric
	local nPosDesc		   := GDFieldPos("UB_DESCRI")						as numeric
	local cNum			   := ""											as character
	local nPercet 		   := val(M->UA_XPROBAB)							as numeric
	local cDtPrev		   := M->UA_XDTFECH 								as character

	if empty(cDtPrev)
		cDtPrev	:= 	substr(cValTochar(lastDay(date())),7,4)+"-"+substr(cValTochar(lastDay(date())),4,2)+"-"+substr(cValTochar(lastDay(date())),1,2)
	else
		cDtPrev := substr(cValTochar(cDtPrev),7,4)+"-"+substr(cValTochar(cDtPrev),4,2)+"-"+substr(cValTochar(cDtPrev),1,2)
	endif


	if lprospect
		nCompany    := val(Posicione('SUS', 1, FWxFilial('SUS')+M->(UA_CLIENTE + M->UA_LOJA), 'US_PIPERUN'))
		cName		:= Posicione('SUS', 1, FWxFilial('SUS')+M->(UA_CLIENTE + M->UA_LOJA), 'US_NOME')
	else
		nCompany    := val(Posicione("SA1", 1, FwXFilial("SA1")+M->UA_CLIENTE + M->UA_LOJA, "A1_PIPERUN"))
		cName		:= Posicione("SA1", 1, FwXFilial("SA1")+M->UA_CLIENTE + M->UA_LOJA, "A1_NOME")
	endif

	if (!empty(cPiperun))
		oRest:setPath(cPath + Alltrim(cPiperun))

		cNum 			:= alltrim(M->UA_NUM)
		jPut["stage_id"				]   := nStage                   //ID da etapa do funil da oportunidade.
		jPut["temperature"			]   := nTemp                    //Temperatura da oportunidade, sendo: 1: muito quente; 2: quente; 3: morna e 4: fria.
		jPut["status"				]   := nStatus                  //Status da oportunidade: 0: aberta, 1: ganha, 3: perdida.
		jPut["value"				]   := nAmount                  //Valor de produtos e serviços (P&S) da oportunidade.
		jPut["pipeline_id"			]	:= nPipeline
		jPut['probability'       	] 	:= nPercet
		jPut['probably_closed_at'	] 	:= cDtPrev
		jPut['company_id'			]   := nCompany

		jPut["tags"] := {}
		aAdd(jPut["tags"		], JsonObject():new())

		if nTemp == 4
			jPut["tags"			][01]["id"          ] := val(__cTagFria)
		elseif nTemp == 3
			jPut["tags"			][01]["id"          ] := val(__cTagMorna)
		elseif nTemp == 1 .OR. nTemp == 2
			jPut["tags"			][01]["id"          ] := val(__cTagQuente)
		endif

		jPut["custom_fields"   ]   := {}

		aAdd(jPut["custom_fields"   ], JsonObject():new())
		jPut["custom_fields"][01]["id"          ] := val(__cFildlocal)
		jPut["custom_fields"][01]["value"       ] := alltrim(FwFilialName(cEmpAnt,cFilAnt,2))

		aAdd(jPut["custom_fields"   ], JsonObject():new())
		jPut["custom_fields"][02]["id"          ] := val(__cNumOrca)
		jPut["custom_fields"][02]["value"       ] := cNum

		dbSelectArea("SF4")
		SF4->(dbSetOrder(01)) //F4_FILIAL+F4_CODIGO
		for nIndex := 01 to len(aCols)
			lSend := Posicione("SF4",1,FwXFilial("SF4") + alltrim(aCols[nIndex][nPosTES]),"F4_PIPERUN")

			if lSend
				aAdd(jPut["custom_fields"   ], JsonObject():new())
				nAdd := len(jPut["custom_fields"   ])

				//produto
				cField1 := __cFildProducts + cValToChar(nIndex)
				jPut["custom_fields"][nAdd]["id"          		] := val(&(cField1))
				jPut["custom_fields"][nAdd]["value"       	   	] := alltrim(aCols[nIndex][nPosProd]) + " - " + alltrim(aCols[nIndex][nPosDesc])

				aAdd(jPut["custom_fields"                 		], JsonObject():new())
				nAdd := len(jPut["custom_fields"          		])

				//quantidade
				cField2 := __cFildQuantity + cValToChar(nIndex)
				jPut["custom_fields"][nAdd]["id"          		] := val(&(cField2))
				jPut["custom_fields"][nAdd]["value"       		] := cValToChar(aCols[nIndex][nPosQuant])

				aAdd(jPut["custom_fields"   			  		], JsonObject():new())
				nAdd := len(jPut["custom_fields"         		])

				//valor unitario
				cField3 := __cFildValue + cValToChar(nIndex)
				jPut["custom_fields"][nAdd]["id"          		] := val(&(cField3))
				jPut["custom_fields"][nAdd]["value"       		] := cValToChar(aCols[nIndex][nPostValNet])

				/*if nIndex < len(aCols)
					aAdd(jPut["custom_fields"   			    ], JsonObject():new())
					nAdd := len(jPut["custom_fields"            ])
					nAdd++
				endif*/
			endif
			//gravar se tiver itens novos
		next nIndex

		if (oRest:put(aHeader, jPut:toJson()))
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			oResponse := JsonObject():new()
			oResponse:fromJson(cBodyStr)
			SUA->(dbSetOrder(01)) //UA_FILIAL + UA_NUM
			if SUA->(dbSeek(FwXFilial("SUA") +SUA->UA_NUM))
				if RecLock("SUA", .F.)
					SUA->UA_XINTREG := "S"
					SUA->UA_XJSON := jPut:toJson()
					SUA->UA_XLOGINT := "Log de integraçăo: " + CRLF + ;
						"Açăo executada: Alteraçăo " + CRLF + ;
						"Retorno: Sucesso na atualizaçăo " + CRLF + ;
						"Data : " + Dtoc(Date()) + CRLF +;
						"Hora: " + time() + CRLF + ;
						"Status: " + cStatus + CRLF + ;
						"Retorno: " + cBodyStr + CRLF
					SUA->(msUnlock())
				endif
			endif
		else
			cStatus  := oRest:getHttpCode()
			cBodyStr := oRest:getResult()
			oResponse := JsonObject():new()
			oResponse:fromJson(cBodyStr)
			SUA->(dbSetOrder(01)) //UA_FILIAL + UA_NUM
			if SUA->(dbSeek(FwXFilial("SUA") +SUA->UA_NUM))
				if RecLock("SUA", .F.)
					SUA->UA_XJSON := jPut:toJson()
					SUA->UA_XLOGINT := "Log de integraçăo: " + CRLF + ;
						"Açăo executada: Alteraçăo: " + CRLF + ;
						"Retorno: Erro na atualizaçăo: " + CRLF + ;
						"Data : " + Dtoc(Date()) + CRLF +;
						"Hora: " + time() + CRLF + ;
						"Status: " + cStatus + CRLF + ;
						"Retorno: " + cBodyStr + CRLF
					SUA->(msUnlock())
				endif
			endif
		endIf
	endif
return

user function DealsDelete()
	FwAlertInfo("DealsDelete")
return

user function lostReason() as array
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath      	   := "/v1/lostReasons"           					as character
	local oReturn          := nil											as object
	local cStatus    	   := ""                                            as character
	local aLost			   := {} 											as array
	local nIndex 		   := 0												as numeric

	oRest:setPath(cPath)

	if (oRest:get(aHeader))

		cStatus  := oRest:getHttpCode()
		cBodyStr := oRest:getResult()
		oReturn := JsonObject():new()
		cError := oReturn:fromJson(cBodyStr)

		if cStatus == SUCCESS
			if len(oReturn['data']) > 0
				for nIndex := 1 to len(oReturn['data'])
					if oReturn['data'][nIndex]['status'] == .T.
						aAdd(aLost,allTrim(cValTochar(oReturn['data'][nIndex]['id']) +" - "+DecodeUTF8(oReturn['data'][nIndex]['name'],'CP1252')))
					endif
				next nIndex
			else
				FwAlertInfo("Năo da motivos de perda cadastrados!")
			endif
		else
			FWAlertError("ERROR: "+cStatus)
		endif
	else
		FWAlertError("ERROR: Năo possivel estabelecer a conexăo!" + CRLF + "Verifique os parâmetros de conexăo.")
	endif

return aLost

user function SendPost(cNumOrc)
	local oRest            := PipeRun.utils.u_getRestObject()               as object
	local aHeader          := PipeRun.utils.u_getBaseHeader()               as array
	local cPath      	   := "/v1/deals"           					    as character
	local cDesc			   := ""											as character
	local jPost            := Nil                                           as json
	local lSend			   := .F.											as logical
	local nUser            := 0                                             as numeric
	local nContact         := 0                                             as numeric
	local nCompany         := 0                                             as numeric
	local nPipeline   	   := 0 											as numeric
	local nStage      	   := 0 											as numeric
	local nTemp       	   := 0 											as numeric
	local nOrigin     	   := 0 											as numeric
	local nAmount     	   := 0 											as numeric
	local aItems		   := {}											as array
	local nIndex           := 0											    as numeric
	local cDTcreate   	   := "" 											as character
	local cNum        	   := "" 											as character
	local cName			   := ""										    as character
	local cAlias 		   := ""											as character
	local nPercet 		   := 0												as numeric
	local cDtPrev		   := "" 											as character
	local lSuccess	       := .F.											as logical
	local cDesTES		   := ""											as character

	if empty(cDtPrev)
		cDtPrev	:= 	substr(cValTochar(lastDay(date())),7,4)+"-"+substr(cValTochar(lastDay(date())),4,2)+"-"+substr(cValTochar(lastDay(date())),1,2)
	else
		cDtPrev := substr(cValTochar(cDtPrev),7,4)+"-"+substr(cValTochar(cDtPrev),4,2)+"-"+substr(cValTochar(cDtPrev),1,2)
	endif



	BEGIN TRANSACTION

		cAlias := GetDeals(cNumOrc)
		While (cAlias)->(!Eof())

			(cAlias)->(dbGoTop())

			nUser       	:= val(Posicione("SA3", 1, FwXFilial("SA3")+(cAlias)->UA_VEND, "A3_PIPERUN"))
			nContact    	:= val(Posicione("SU5", 1, FwXFilial("SU5")+(cAlias)->UA_CODCONT, "U5_PIPERUN"))
			nPipeline 		:= val((cAlias)->UA_XFUNIL)
			nStage			:= val((cAlias)->UA_XSTAGE)
			nTemp 			:= val((cAlias)->UA_XTEMP)
			nOrigin			:= val((cAlias)->UA_XORIGEM)
			cNum 			:= alltrim((cAlias)->UA_NUM)
			//nAmount 		:= TotalAmount(aCols)
			cDTcreate		:= (cAlias)->UA_TIMESTA
			lprospect		:= iif((cAlias)->UA_PROSPEC == "F", .F., .T.)
			nPercet		    := val((cAlias)->UA_XPROBAB)

			if lprospect
				nCompany    := val(Posicione('SUS', 1, FWxFilial('SUS')+(cAlias)->(UA_CLIENTE + (cAlias)->UA_LOJA), 'US_PIPERUN'))
				cName		:= Posicione('SUS', 1, FWxFilial('SUS')+(cAlias)->(UA_CLIENTE + (cAlias)->UA_LOJA), 'US_NOME')
			else
				nCompany    := val(Posicione("SA1", 1, FwXFilial("SA1")+(cAlias)->UA_CLIENTE + (cAlias)->UA_LOJA, "A1_PIPERUN"))
				cName		:= Posicione("SA1", 1, FwXFilial("SA1")+(cAlias)->UA_CLIENTE + (cAlias)->UA_LOJA, "A1_NOME")
			endif

			if empty(cDTcreate)
				cDTcreate := left(fwtimestamp(6),10)
			endif

			cTitle 			:= allTrim(cNum) +  " - " + allTrim(cName) +" | " + alltrim(FwFilialName(cEmpAnt,cFilAnt,1))

			jPost := JsonObject():new()

			jPost["pipeline_id"			]   := nPipeline                //ID do funil da oportunidade.
			jPost["stage_id"			]   := nStage                   //ID da etapa do funil da oportunidade.
			jPost["title"				]   := cTitle            		//Título da oportunidade.
			jPost["temperature"			]   := nTemp                    //Temperatura da oportunidade, sendo: 1: muito quente; 2: quente; 3: morna e 4: fria.
			jPost["origin_id"			]   := nOrigin                  //ID da origem da oportunidade.
			jPost["owner_id"			]   := nUser                    //ID do usuário responsável pela oportunidade.
			jPost["person_id"			]   := nContact                 //ID da pessoa de contato da oportunidade.
			jPost["company_id"			]   := nCompany                 //ID da empresa da oportunidade.
			jPost["created_at"			]	:= cDTcreate    			//Data de criaçăo da oportunidade.
			jPost["status"				]   := 0                        //Status da oportunidade: 0: aberta, 1: ganha, 3: perdida.
			jPost['probability'       	] 	:= nPercet
			jPost['probably_closed_at'	] 	:= cDtPrev

			jPost["tags"] := {}
			aAdd(jPost["tags"		], JsonObject():new())

			if nTemp == 4
				jPost["tags"			][01]["id"          ] := val(__cTagFria)
			elseif nTemp == 3
				jPost["tags"			][01]["id"          ] := val(__cTagMorna)
			elseif nTemp == 1 .OR. nTemp == 2
				jPost["tags"			][01]["id"          ] := val(__cTagQuente)
			endif

			jPost["custom_fields"   ]   := {}

			aAdd(jPost["custom_fields"           ], JsonObject():new())
			jPost["custom_fields"][01]["id"          ] := val(__cFildlocal)
			jPost["custom_fields"][01]["value"       ] := alltrim(FwFilialName(cEmpAnt,cFilAnt,2))

			aAdd(jPost["custom_fields"   ], JsonObject():new())
			jPost["custom_fields"][02]["id"          ] := val(__cNumOrca)
			jPost["custom_fields"][02]["value"       ] := alltrim(cNum)

			dbSelectArea("SUB")
			SUB->(dbSetOrder(1)) //UB_FILIAL + UB_NUM + UB_ITEM + UB_PRODUTO
			if SUB->(dbSeek(FwXFilial("SUB")+padR(cNumOrc,__nTamNum)))
				while !SUB->(EOF()) .AND. FwXFilial("SUB") + cNumOrc = FwXFilial("SUB") + SUB->UB_NUM
					cDesc := Posicione("SB1", 1, FwXFilial("SB1")+padR(SUB->UB_PRODUTO, __nTamProd), "B1_DESC")
					aAdd(aItems,{SUB->UB_ITEM, SUB->UB_PRODUTO, cDesc, SUB->UB_QUANT, SUB->UB_ZVLNET, SUB->UB_TES})
					nAmount +=  (SUB->UB_QUANT * SUB->UB_ZVLNET)
					SUB->(dbSkip())
				endDo
			endif

			if len(aItems) > 0
				dbSelectArea("SF4")
				SF4->(dbSetOrder(01)) //F4_FILIAL+F4_CODIGO
				for nIndex := 01 to len(aItems)
					lSend := Posicione("SF4",1,FwXFilial("SF4") + alltrim(aItems[nIndex][6]),"F4_PIPERUN")
					if lSend
						aAdd(jPost["custom_fields"   ], JsonObject():new())
						nAdd := len(jPost["custom_fields"   ])

						//produto
						cField1 := __cFildProducts + cValToChar(nIndex)
						jPost["custom_fields"][nAdd]["id"          ] := val(&(cField1))
						jPost["custom_fields"][nAdd]["value"       ] := alltrim(aItems[nIndex][2]) + " - " + alltrim(aItems[nIndex][3])

						aAdd(jPost["custom_fields"                 ], JsonObject():new())
						nAdd := len(jPost["custom_fields"          ])

						//quantidade
						cField2 := __cFildQuantity + cValToChar(nIndex)
						jPost["custom_fields"][nAdd]["id"          ] := val(&(cField2))
						jPost["custom_fields"][nAdd]["value"       ] := cValToChar(aItems[nIndex][4])

						aAdd(jPost["custom_fields"   			  ], JsonObject():new())
						nAdd := len(jPost["custom_fields"         ])

						//valor unitario
						cField3 := __cFildValue + cValToChar(nIndex)
						jPost["custom_fields"][nAdd]["id"          ] := val(&(cField3))
						jPost["custom_fields"][nAdd]["value"       ] :=  cValToChar(aItems[nIndex][5])
						/*if nIndex < len(aItems)
							aAdd(jPost["custom_fields"   			   ], JsonObject():new())
							nAdd := len(jPost["custom_fields"          ])
							nAdd++
						endif*/
					else
						cDesTES := Capital(Posicione("SF4",1,FwXFilial("SF4") + alltrim(aItems[nIndex][6]),"F4_FINALID"))
						FwAlertInfo("O item " + alltrim(aItems[nIndex][2]) + " - " + alltrim(aItems[nIndex][3]) + CRLF + ;
							", năo sera enviado pois esta configurado com a TES: " + alltrim(aItems[nIndex][6]) + " - " +cDesTES, "Atençăo!")
					endif
				next nIndex
			endif

			jPost["value"			]   := nAmount                  //Valor de produtos e serviços (P&S) da oportunidade.

			oRest:setPath(cPath)

			if lSend
				if nUser <=0
					FwAlertInfo("Cliente / Prospect năo vinculo ao Piperun!")
				elseif nContact <= 0
					FwAlertInfo("Contato năo vinulado ao Piperun!")
				elseif nPipeline <= 0 .or. nStage <=0
					FwAlertInfo("Funil ou Etapa năo vinculada ao Piperun!")
				endIf

				if nUser > 0 .and. nContact  > 0 .and. nPipeline > 0 .and. nStage > 0
					oRest:setPostParams(jPost:toJson())
					lSuccess := .T.
				endif
			else
				lSuccess := .F.
			endIf

			if lSuccess
				if (oRest:post(aHeader))
					cStatus  := oRest:getHttpCode()
					cBodyStr := oRest:getResult()
					oResponse := JsonObject():new()
					oResponse:fromJson(cBodyStr)
					if (oResponse:hasProperty('data'))
						SUA->(dbSetOrder(01)) //UA_FILIAL + UA_NUM
						if SUA->(dbSeek(SUA->UA_FILIAL + SUA->UA_NUM))
							if RecLock("SUA", .F.)
								SUA->UA_XINTREG := "S"
								SUA->UA_PIPERUN := cValToChar(oResponse['data']['id'])
								SUA->UA_XSTATUS := "0"
								SUA->UA_XJSON := jPost:toJson()
								SUA->UA_XLOGINT := "Log de integraçăo: " + CRLF + ;
									"Acăo : Enviar orçamento" + CRLF + ;
									"Retorno: Sucesso na inclusăo: " + CRLF + ;
									"Data : " + Dtoc(Date()) + CRLF +;
									"Hora: " + time() + CRLF + ;
									"Status: " + cStatus + CRLF + ;
									"Retorno: " + cBodyStr + CRLF
								SUA->(msUnlock())
							endif
							lSuccess := .T.
						endif
					endif
				else
					cStatus  := oRest:getHttpCode()
					cBodyStr := oRest:getResult()
					SUA->(dbSetOrder(01)) //UA_FILIAL + UA_NUM
					if SUA->(dbSeek(SUA->UA_FILIAL + SUA->UA_NUM))
						if RecLock("SUA", .F.)
							SUA->UA_XINTREG := "N"
							SUA->UA_PIPERUN := ""
							SUA->UA_XJSON := jPost:toJson()
							SUA->UA_XLOGINT := "Log de integraçăo: " + CRLF + ;
								"Acăo : Enviar orçamento" + CRLF + ;
								"Retorno: Erro na inclusăo: " + CRLF + ;
								"Data : " + Dtoc(Date()) + CRLF +;
								"Hora: " + time() + CRLF + ;
								"Status: " + cStatus + CRLF + ;
								"Retorno: " + cBodyStr + CRLF
							SUA->(msUnlock())
						endif
					endif
					FWAlertError(cBodyStr, "Năo foi possivel realizar a integraçăo!")
				endif
			endif
			(cAlias)->(dbSkip())
		endDo
		(cAlias)->(dbCloseArea())
	END TRANSACTION

return lSuccess

static function GetDeals(cNumOrc) as character
	local cQuery 	:= ""		as character
	local cAlias	:= ""   	as character
	local oQuery 	:= nil 		as object

	cQuery :=  "SELECT  * "
	cQuery +=  "FROM " + RetSqlName("SUA") + " SUA "
	cQuery +=  "WHERE UA_NUM = ? "
	cQuery +=  "AND UA_FILIAL = ? "
	cQuery +=  "AND UA_PIPERUN = ? "
	cQuery +=  "AND D_E_L_E_T_ = '' "

	oQuery := FWPreparedStatement():New(cQuery)
	oQuery:SetString(1,cNumOrc)
	oQuery:SetString(2, cFilAnt)
	oQuery:SetString(3, '')
	cQuery := oQuery:GetFixQuery()
	cAlias := MPSysOpenQuery(cQuery)

return cAlias

static function stageOrder(cPipeline) as numeric
	local nOrder 	:= 0 		as numeric
	local cQuery 	:= ""		as character
	local cAlias	:= ""   	as character
	local oQuery 	:= nil 		as object

	cQuery :=  " SELECT TOP 1 "
	cQuery +=  " ZTA_ETAPAS "
	cQuery +=  " FROM " + RetSqlName("ZTA")
	cQuery +=  " WHERE ZTA_PIPERU = ? "
	cQuery +=  " AND D_E_L_E_T_ = '' "
	cQuery +=  " ORDER BY ZTA_ORDER DESC "

	oQuery := FWPreparedStatement():New(cQuery)
	oQuery:SetString(1,cPipeline)
	cQuery := oQuery:GetFixQuery()
	cAlias := MPSysOpenQuery(cQuery)

	nOrder := val((cAlias)->ZTA_ETAPAS)

return nOrder
