#Include "Protheus.CH"

User function fDuplSPG()

Local _cAlias		:= "SPGAlias"
Local _cAliasDUP	:= "DUP"
Local _lFirst		:= .T.

dbSelectArea( "SPG" )
SPG->( dbSetOrder( 01 ) )

ConOut( "fDuplSPG - Selecionando registros com duplicidade 0401 ..." )

BeginSQL Alias _cAlias
	Select Distinct
		PG_FILIAL+PG_TURNO+PG_MAT+PG_ORDEM+PG_DATA+Str(PG_HORA)+PG_FUNCAO+PG_RELOGIO+PG_GIRO+PG_FLAG+PG_CC+PG_APONTA+PG_TPMARCA+PG_PAPONTA+PG_PROCES+PG_ROTEIR+PG_PERIODO+PG_NUMPAG+PG_DEPTO+PG_POSTO+PG_CODFUNC+PG_DATAAPO+PG_SEMANA+PG_NUMREP+PG_TPMCREP+PG_TIPOREG+PG_MOTIVRG+PG_EMPORG+PG_FILORG+PG_MATORG+PG_DHORG+PG_IDORG+PG_DATAALT+PG_HORAALT+PG_USUARIO+Str(PG_SEQJRN)+PG_LONGIT+PG_LATITU As Linha
	From
		SPG010 
	Where PG_DATA >= '20190101'
		And PG_FILIAL = '0401'
		And D_E_L_E_T_ = ' '
		And PG_FILIAL+PG_TURNO+PG_MAT+PG_ORDEM+PG_DATA+Str(PG_HORA)+PG_FUNCAO+PG_RELOGIO+PG_GIRO+PG_FLAG+PG_CC+PG_APONTA+PG_TPMARCA+PG_PAPONTA+PG_PROCES+PG_ROTEIR+PG_PERIODO+PG_NUMPAG+PG_DEPTO+PG_POSTO+PG_CODFUNC+PG_DATAAPO+PG_SEMANA+PG_NUMREP+PG_TPMCREP+PG_TIPOREG+PG_MOTIVRG+PG_EMPORG+PG_FILORG+PG_MATORG+PG_DHORG+PG_IDORG+PG_DATAALT+PG_HORAALT+PG_USUARIO+Str(PG_SEQJRN)+PG_LONGIT+PG_LATITU
		In (
				Select
					PG_FILIAL+PG_TURNO+PG_MAT+PG_ORDEM+PG_DATA+Str(PG_HORA)+PG_FUNCAO+PG_RELOGIO+PG_GIRO+PG_FLAG+PG_CC+PG_APONTA+PG_TPMARCA+PG_PAPONTA+PG_PROCES+PG_ROTEIR+PG_PERIODO+PG_NUMPAG+PG_DEPTO+PG_POSTO+PG_CODFUNC+PG_DATAAPO+PG_SEMANA+PG_NUMREP+PG_TPMCREP+PG_TIPOREG+PG_MOTIVRG+PG_EMPORG+PG_FILORG+PG_MATORG+PG_DHORG+PG_IDORG+PG_DATAALT+PG_HORAALT+PG_USUARIO+Str(PG_SEQJRN)+PG_LONGIT+PG_LATITU
				From
					SPG010
				Where PG_DATA >= '20190101'
					And PG_FILIAL = '0401' 
					And D_E_L_E_T_ = ' '
				Group By
					PG_FILIAL+PG_TURNO+PG_MAT+PG_ORDEM+PG_DATA+Str(PG_HORA)+PG_FUNCAO+PG_RELOGIO+PG_GIRO+PG_FLAG+PG_CC+PG_APONTA+PG_TPMARCA+PG_PAPONTA+PG_PROCES+PG_ROTEIR+PG_PERIODO+PG_NUMPAG+PG_DEPTO+PG_POSTO+PG_CODFUNC+PG_DATAAPO+PG_SEMANA+PG_NUMREP+PG_TPMCREP+PG_TIPOREG+PG_MOTIVRG+PG_EMPORG+PG_FILORG+PG_MATORG+PG_DHORG+PG_IDORG+PG_DATAALT+PG_HORAALT+PG_USUARIO+Str(PG_SEQJRN)+PG_LONGIT+PG_LATITU
				Having Count(*) > 01 )
EndSQL

conout( "Finalizou selecao dos registros com duplicidade" )

While ( _cAlias )->( !Eof() )

	_lFirst := .T.

	ConOut( "Analisando registro: " + ( _cAlias )->Linha )

	BeginSQL Alias _cAliasDUP
		Select
			R_E_C_N_O_ As RegDUP
		From
			SPG010
		Where PG_FILIAL+PG_TURNO+PG_MAT+PG_ORDEM+PG_DATA+Str(PG_HORA)+PG_FUNCAO+PG_RELOGIO+PG_GIRO+PG_FLAG+PG_CC+PG_APONTA+PG_TPMARCA+PG_PAPONTA+PG_PROCES+PG_ROTEIR+PG_PERIODO+PG_NUMPAG+PG_DEPTO+PG_POSTO+PG_CODFUNC+PG_DATAAPO+PG_SEMANA+PG_NUMREP+PG_TPMCREP+PG_TIPOREG+PG_MOTIVRG+PG_EMPORG+PG_FILORG+PG_MATORG+PG_DHORG+PG_IDORG+PG_DATAALT+PG_HORAALT+PG_USUARIO+Str(PG_SEQJRN)+PG_LONGIT+PG_LATITU = %Exp:( _cAlias )->Linha%
			And D_E_L_E_T_ = ' '
		Order By 
			PG_FILIAL+PG_TURNO+PG_MAT+PG_ORDEM+PG_DATA+Str(PG_HORA)+PG_FUNCAO+PG_RELOGIO+PG_GIRO+PG_FLAG+PG_CC+PG_APONTA+PG_TPMARCA+PG_PAPONTA+PG_PROCES+PG_ROTEIR+PG_PERIODO+PG_NUMPAG+PG_DEPTO+PG_POSTO+PG_CODFUNC+PG_DATAAPO+PG_SEMANA+PG_NUMREP+PG_TPMCREP+PG_TIPOREG+PG_MOTIVRG+PG_EMPORG+PG_FILORG+PG_MATORG+PG_DHORG+PG_IDORG+PG_DATAALT+PG_HORAALT+PG_USUARIO+Str(PG_SEQJRN)+PG_LONGIT+PG_LATITU,
			R_E_C_N_O_ 
	EndSQL
		
	While ( _cAliasDUP )->( !Eof() )
	
		If !_lFirst

			SPG->( dbGoTo( ( _cAliasDUP )->RegDUP ) )
		
			If SPG->( Recno() ) == ( _caliasDUP )->RegDUP

				ConOut( "Atualizado registro: " + AllTrim( Str( ( _cAliasDUP )->RegDUP ) ) )

				RecLock( "SPG", .F. )
				SPG->PG_FILIAL:= "XXXX"
				SPG->( MsUnLock() )

			EndIf
		
		else
			_lFirst := .F.
		EndIf

		( _cAliasDUP )->( dbSkip() )
		
	EndDo

	( _cAliasDUP )->( dbCloseArea() )
	
	( _cAlias )->( dbSkip() )
	
EndDo

( _cAlias )->( dbCloseArea() )

Return ( Nil )