   nValICM  := 0
EndIf    

IF SUA->UA_NATOPER == "1"
   nValICM = nTotValIPI * (nPercICM / 100)
ENDIF                               

TOTPED := nVlDesc  
nFrete   := SUA->UA_FRETE

