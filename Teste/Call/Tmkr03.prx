// Substituido pelo assistente de conversao do AP5 IDE em 04/07/02 ==> Function ImpRodape

Static Function ImpRodape()
    li := li+1
    @ li,000 PSAY Replicate("-",limite)
    li := li+1
    nPcICM:=0  
    nVlIcm:=0
    dbSelectArea("SA1")
    dbSeek(xFilial()+SUA->UA_CLIENTE+SUA->UA_LOJA)
	If SA1->A1_ME=="S" .AND. SA1->A1_EST=="BA"  .and. cTES<>"529"
	  nVlIcm:=nBaseIcm*0.07 
	  nPcICM:=7
	Else             
	  If SA1->A1_EST = "BA"
	     nPcICM := 17
         nVlIcm:=nBaseIcm*(nPcICM/100)
	  Else
	     nPcICM := 12
         nVlIcm:=nBaseIcm*(nPcICM/100)
	  Endif   
	  /*
