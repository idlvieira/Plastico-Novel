/*/
// Substituido pelo assistente de conversao do AP5 IDE em 04/07/02 ==> Function ImpItem
Static Function ImpItem()
nIPI       := 0
nVipi      := 0
nBaseIPI   := 100
nValBase   := 0
nValItem   := 0
lIpiBruto  := IIF(GETMV("MV_IPIBRUT")=="S",.T.,.F.)

dbSelectArea("SB1")
dbSeek(xFilial()+SUB->UB_PRODUTO)
dbSelectArea("SF4")
dbSeek(xFilial()+SUB->UB_TES)
IF SF4->F4_IPI == "S"
	nBaseIPI  := IIF(SF4->F4_BASEIPI > 0,SF4->F4_BASEIPI,100)
	nIPI 	  := SB1->B1_IPI
// Alterado por ElisŌngela em 26/09/02 
// Objetivo: Atender alterańŃo de desconto.
	nValBase  := If(lIPIBruto .And. ((SUB->UB_VRUNIT*100)/nPerc) > 0,((SUB->UB_VRUNIT*100)/nPerc),((SUB->UB_VLRITEM*100)/nPerc))*SUB->UB_QUANT
//	nValBase  := If(lIPIBruto .And. SUB->UB_VRUNIT > 0,SUB->UB_VRUNIT,SUB->UB_VLRITEM)*SUB->UB_QUANT
	nVipi	  := nValBase * (nIPI/100)*(nBaseIPI/100)
Endif
    
// WELLINGTON 10/10/2013 IPI EMPRESA NORMAL

IF SF4->F4_IPI == "S"
	nBaseIPI  := IIF(SF4->F4_BASEIPI > 0,SF4->F4_BASEIPI,100)
	nIPI 	  := SB1->B1_IPI
// Alterado por ElisŌngela em 26/09/02 
// Objetivo: Atender alterańŃo de desconto.
//	nValBase  := If(lIPIBruto .And. ((SUB->UB_VRUNIT*100)/nPerc) > 0,((SUB->UB_VRUNIT*100)/nPerc),((SUB->UB_VLRITEM*100)/nPerc))*SUB->UB_QUANT
	nValBase  := If(lIPIBruto .And. SUB->UB_VRUNIT > 0,SUB->UB_VRUNIT,SUB->UB_VLRITEM)*SUB->UB_QUANT
	nVipi	  := nValBase * (nIPI/100)*(nBaseIPI/100)
Endif
                                           
// WELLINGTON 10/10/2013 IPI MICROEMPRESA 

IF SF4->F4_IPI == "S" .AND. cME=="S" .AND. cEstCli=="BA"
	nBaseIPI  := IIF(SF4->F4_BASEIPI > 0,SF4->F4_BASEIPI,100)
	nIPI 	  := SB1->B1_IPI
// Alterado por ElisŌngela em 26/09/02 
// Objetivo: Atender alterańŃo de desconto.
	nValBase  := If(lIPIBruto .And. ((SUB->UB_VRUNIT*100)/nPerc) > 0,((SUB->UB_VRUNIT*100)/nPerc),((SUB->UB_VLRITEM*100)/nPerc))*SUB->UB_QUANT
//	nValBase  := If(lIPIBruto .And. SUB->UB_VRUNIT > 0,SUB->UB_VRUNIT,SUB->UB_VLRITEM)*SUB->UB_QUANT
	nVipi	  := nValBase * (nIPI/100)*(nBaseIPI/100)
Endif      


cTES:=SUB->UB_TES      

// ALTERAdo POR MONICA EM 08/10/02
IF cME=="S" .AND. cEstCli=="BA"  .AND. SUB->UB_TES<>"529" .AND. SF4->F4_IPI == "S" 
   nVlUnit:=INT(ROUND((SUB->UB_VRUNIT*100)/nPerc,2)*100)/100     
   nVlDesc:=nVlDesc+(INT(nVlUnit*SUB->UB_QUANT*100)/100-INT(SUB->UB_VRUNIT*SUB->UB_QUANT*100)/100)
Else   
   IF cME=="S" .AND. cEstCli=="BA"  .AND. SUB->UB_TES<>"529" .AND. SF4->F4_IPI == "N"  
     // nVlUnit := SUB->UB_VRUNIT    
      nVlUnit := SUB->UB_VUNTREA 
      nVlDesc:=nVlDesc+((nVlUnit*SUB->UB_QUANT)*0.1075)        
   ELSE 
      nVlUnit:=SUB->UB_VRUNIT
   ENDIF   
   
EndIf
//nVlUnt:=SUB->UB_VRUNIT

@ li,000 PSAY Left(SUB->UB_PRODUTO,11)
@ li,012 PSAY Left(SB1->B1_DESC,29)
@ li,042 PSAY SUB->UB_CM         Picture "@E 999.99"
@ li,049 PSAY SUB->UB_QUANT      Picture "@E 999,999"  // cPictQtd 
@ li,058 PSAY "__________"
@ li,070 PSAY "_____"
@ li,077 PSAY "__________"
//@ li,089 PSAY SUB->UB_VRUNIT     Picture PesqPict("SUB","UB_VRUNIT",12)
@ li,089 PSAY nVlUnit            Picture PesqPict("SUB","UB_VRUNIT",12)
nValItem   := int(nVlUnit*SUB->UB_QUANT*100)/100
nVlIt      := int(SUB->UB_VRUNIT*SUB->UB_QUANT*100)/100

// Alterado por ElisŌngela em 26/09/02 
// Objetivo: Atender alterańŃo de desconto.
//nPercIPI   := Round( ((nVipi/nValItem)*100),2 )
@ li,103 PSAY nValItem           Picture PesqPict("SUB","UB_VLRITEM",14)
If lSuframa
   nPercIpi := 0
   nVIpi    := 0
EndIf
@ li,119 PSAY nIPI           Picture "99"
// Alterado por ElisŌngela em 26/09/02 
// Objetivo: Atender alterańŃo de desconto.
//@ li,119 PSAY nPercIPI           Picture "99"
@ li,122 PSAY nVIpi              Picture "@E 999,999.99"
      

ntotValCM  := nTotValCM + ((SUB->UB_CM/100)*nValItem)
nTotIPI    := nTotIPI + nVipi
nTotVal    := nTotVal + nVlIt   //nValItem
nTotValIPI := nTotVal + nTotIPI

nFrete   := SUA->UA_FRETE


dbSelectArea("SUB")
If !Empty(UB_NRFG)
   fGrav := fGrav + UB_ITEM + ":" + UB_NRFG + "  "
Endif

// Substituido pelo assistente de conversao do AP5 IDE em 04/07/02 ==> __Return ( NIL )
Return( NIL )        // incluido pelo assistente de conversao do AP5 IDE em 04/07/02

