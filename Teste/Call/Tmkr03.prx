User Function Tmkr03()        // incluido pelo assistente de conversao do AP5 IDE em 04/07/02

/*/
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒│ Programa │ TMKR03   │ Autor │   Marcos L. Santos    │ Data │ 01.12.99 │▒▒
▒▒├──────────┼──────────┴───────┴───────────────────────┴──────┴──────────┤▒▒
▒▒│Descrićģo │ Emissao do Pedido de Venda  (Plasticos Novel)              │▒▒
▒▒├──────────┼────────────────────────────────────────────────────────────┤▒▒
▒▒│ Uso      │ Generico                                                   │▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
/*/       

SetPrvt("WNREL,TAMANHO,TITULO,CDESC1,CDESC2,CDESC3")
SetPrvt("NREGISTRO,CKEY,NINDEX,CINDEX,CCONDICAO,LEND")
SetPrvt("CPERG,ARETURN,NOMEPROG,NLASTKEY,NBEGIN,ALINHA")
SetPrvt("LI,LIMITE,LRODAPE,CPICTQTD,NTOTQTD,NTOTVAL")
SetPrvt("NTOTIPI,APEDCLI,CSTRING,COMPRA1,MV_PEDDE,MV_PEDATE")
SetPrvt("MV_PAR01,MV_PAR02,NREG,NTOTVALCM,CPEDIDO,CNOMSUP")
SetPrvt("CHEADER,NPED,CMOEDA,CCAMPO,CCOMIS,CHEADER2")
SetPrvt("CMIDIA,CCIDCLI,CESTCLI,CENDCLI,CCEPCLI,CCOBCLI")
SetPrvt("CENTCLI,CNOMCLI,CCGCCLI,CIECLI,CBAICLI,CBAICOB")
SetPrvt("CCIDCOB,CTELCLI,CFAXCLI,CCONTAT,LSUFRAMA,LZFRANCA")
SetPrvt("CQQCOR,CNATOPER,NIPI,NVIPI,NBASEIPI,NVALBASE")
SetPrvt("NVALITEM,LIPIBRUTO,NPERCIPI,NTOTVALIPI,CGRAV,CTIPOG1")
SetPrvt("CTIPOG2,NPERCMFIN,NVALICM,NVALMERC,NPERCICM,CCIFATE,NFRETE")
SetPrvt("CTCARGA,NPERRET,CESTADO,TNORTE,CINSCRCLI,")

wnrel            := ""
tamanho          := "M"
titulo           := "Emissao da Confirmacao do Pedido"
cDesc1           := "Emissäo da confirmacäo dos pedidos de venda, de acordo com"
cDesc2           := "intervalo informado na općäo Parāmetros."
cDesc3           := " "
nRegistro        := 0
cKey             := ""
nIndex           := ""
cIndex           := ""//  && Variaveis para a criacao de Indices Temp.
cCondicao        := ""
lEnd             := .T.
cPerg            := ""
aReturn          := { "Zebrado", 1,"Administracao", 2, 2, 1, "",0 }
nomeprog         := "TMKR03"
nLastKey         := 0
nBegin           := 0
aLinha           := { }
li               := 80
limite           := 132
lRodape          := .F.
// cPictQtd         :=""
nTotQtd          := 0
nTotVal          := 0
nTotIPI          := 0
nFrete           := 0
nVlDesc          := 0        
aPedCli          := {}
wnrel            := "TMKR03"
cString          := "SUB"
COMPRA1	 	     := "" // variavel para definir se eh a 1a. Copra do Cliente
MSTATUS          := " "                        


Public nPerc
private nvlicm
private cTES
private cEstCli
private cME  
PRIVATE MSTATUS 
//X:=Upper(FUNNAME())

If TYPE("uPorPrograma") == "U"
   cPerg            :="MTR730"
   //┌─────────────────────────────────────────────────────────────┐
   //│ Variaveis utilizadas para parametros                        │
   //│ mv_par01              Do Pedido                             │
   //│ mv_par02              Ate o Pedido                          │
   //└─────────────────────────────────────────────────────────────┘

   pergunte(cPerg,.F.)
   wnrel :=SetPrint(cString,wnrel,cPerg,titulo,cDesc1,cDesc2,cDesc3,.F.,,,,,.F.)
Else
   mv_pedde  := SC5->C5_NUM
   mv_pedate := SC5->C5_NUM
//   mv_pedde  := SUA->UA_NUM
//   mv_pedate := SUA->UA_NUM
//   mv_par01:=SUA->UA_NUM
//   mv_par02:=SUA->UA_NUM
   wnrel:=SetPrint(cString,wnrel,cPerg,titulo,cDesc1,cDesc2,cDesc3,.F.,,,,,.F.)
Endif

// wnrel:=SetPrint(cString,wnrel,cPerg,@Titulo,cDesc1,cDesc2,cDesc3,.F.)

If nLastKey==27
	Return
Endif

SetDefault(aReturn,cString)

If nLastKey==27
	Return
Endif

#IFDEF WINDOWS
    RptStatus({||C730Imp()})// Substituido pelo assistente de conversao do AP5 IDE em 04/07/02 ==>     RptStatus({||Execute(C730Imp)})
    Return
// Substituido pelo assistente de conversao do AP5 IDE em 04/07/02 ==>     Function C730IMP
Static Function C730IMP()
#ENDIF

//┌──────────────────────────────────────────────────────────────┐
//│ Define Variaveis                                             │
//└──────────────────────────────────────────────────────────────┘
tamanho        := "M"
titulo         := "EMISSAO DA CONFIRMACAO DO PEDIDO"
cDesc1         := "Emissäo da confirmacäo dos pedidos de venda, de acordo com"
cDesc2         := "intervalo informado na općäo Parāmetros."
cDesc3         := " "
nRegistro      := 0
cKey           := ""
nIndex         := ""
cIndex         := "" //  && Variaveis para a criacao de Indices Temp.
cCondicao      := ""
Private nFrete := 0
@ 0,0 PSay AvalImp(limite)
pergunte("MTR730",.F.)
//┌─────────────────────────────────────────────────────────────┐
//│ Variaveis utilizadas para parametros                        │
//│ mv_par01              Do Pedido                             │
//│ mv_par02              Ate o Pedido                          │
//└─────────────────────────────────────────────────────────────┘

If Val(AllTrim(mv_pedate)) > Val(Alltrim(mv_pedde))
   nReg := Val(mv_pedate) - Val(mv_pedde)
Else
   nReg := 10
Endif
  
SetRegua(nReg)  // (RecCount())		// Total de Elementos da regua

If TYPE("uPorPrograma") == "U"
   mv_pedde  := mv_par01
   mv_pedate := mv_par02
Endif

Dbselectarea("SC5")
Dbsetorder(1)
Dbseek(xFilial()+mv_pedde,.T.)
nTotQtd   := 0
nTotVal   := 0
nTotValCM := 0
nTotIPI   := 0
nFrete    := 0

While !Eof() .And. SC5->C5_NUM <= mv_pedate
	
   	nTotQtd   := 0
   	nTotVal   := 0
    nTotValCM := 0
    nTotIPI   := 0        
    nFrete    := 0     
	
    DbSelectArea("SUA")
    DbSetOrder(8)
    DbSeek(xFilial()+SC5->C5_NUM,.T.)
    xNum := SUA->UA_NUM
	dbSelectArea("SA4")
	dbSeek(xFilial()+SUA->UA_TRANSP)
	dbSelectArea("SA3")
    dbSeek(xFilial()+SUA->UA_SUPLENT)
    cNomSup := A3_NREDUZ
	dbSeek(xFilial()+SUA->UA_VEND)
	dbSelectArea("SE4")
	dbSeek(xFilial()+SUA->UA_CONDPG)
	
	// cPictQtd := PESQPICTQT("UB_QUANT",10)
	nRegistro:= RECNO()
	#IFNDEF WINDOWS
	If LastKey() == 286    //ALT_A
		lEnd := .t.
		exit
	End
	#ENDIF
	
	IF LastKey() == 286
		@Prow()+1,001 PSAY "CANCELADO PELO OPERADOR"
		Exit
	Endif

	//┌──────────────────────────────────────────────────────────────┐
	//│ Monta tabela de pedidos do cliente p/ o cabećalho            │
	//└──────────────────────────────────────────────────────────────┘
/*	aPedCli := {}
	While !Eof() .And. SUB->UB_NUM == SUA->UA_NUM
		// IF !Empty(SUB->UB_PEDCLI) .and. Ascan(aPedCli,SUB->UB_PEDCLI) == 0
		//	AAdd(aPedCli,SUB->UB_PEDCLI)
		// ENDIF
		dbSkip()
	Enddo
*/	// aSort(aPedCli)
        nBaseIcm:=0
      	li := 0
	    SetPrc(0,0)
       	ImpCabec()
	// li:=li+1
	
    fGrav := "FG -> "
	dbSelectArea("SUB")
    DbSetOrder(1)
	dbSeek(xFilial()+xNum,.T.)
	While !Eof() .And. SUB->UB_NUM == xNum
		#IFNDEF WINDOWS
		If LastKey() == 286    //ALT_A
			lEnd := .t.
		End
		#ENDIF
		
		IF LastKey()==27
			@Prow()+1,001 PSAY "CANCELADO PELO OPERADOR"
			Exit
		Endif
		
        If li > 34
        	If lRodape
            	li := 35
                ImpRodape()
                lRodape := .F.
			    li:=li+5
       		Endif
       Endif
        nBaseIcm:=nBaseIcm+SUB->UB_BASEICM
		
		ImpItem()
		dbSkip()
		li := li+1
	Enddo

	@ li,093 PSAY "DESCONTO ME -->"
	@ li,110 PSAY nVlDesc   PICTURE "@E@Z 999,999.99"
   //	nVlDesc:=0
	IF lRodape
 		li := 35                
   	    ImpRodape()
	   	lRodape:=.F.
	   	li:=li+2
	Endif

	dbSelectArea("SC5")
	dbSkip()
	
	IncRegua()
Enddo

//┌──────────────────────────────────────────────────────────────┐
//│ Deleta Arquivo Temporario e Restaura os Indices Nativos.     │
//└──────────────────────────────────────────────────────────────┘

RetIndex("SUA")
//DBSetFilter()

//Ferase(cIndex+OrdBagExt())

dbSelectArea("SUB")
// DBSetFilter()
dbSetOrder(1)
dbGotop()
Set device to screen

If aReturn[5] == 1
	Set Printer To
	dbCommitAll()
	OurSpool(wnrel)
Endif

MS_FLUSH()

/*/
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒│Funcao    │ ImpCabec │ Autor │ Claudinei M. Benzi    │ Data │ 05.11.92 │▒▒
▒▒├──────────┼──────────┴───────┴───────────────────────┴──────┴──────────┤▒▒
▒▒│Descricao │ Emissao da Pré-Nota                                        │▒▒
▒▒├──────────┼────────────────────────────────────────────────────────────┤▒▒
