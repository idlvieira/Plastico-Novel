	  nParam:=GETMV("MV_ESTICM")
	  For j:=1 to len(nParam)
	    If substr(nParam,j,2)==SA1->A1_EST 
	       nPcICM:=val(substr(nParam,j+2,2))
	       nVlIcm:=nBaseIcm*(nPcICM/100)
	   
	    ENDIF 
	    J:=J+3
	  next
	  */
	Endif
