▒▒│ Programa │ ELIMRES   │ Autor │   Eliene Cerqueira   │ Data │ 11.11.04 │▒▒
▒▒├──────────┼──────────┴───────┴───────────────────────┴──────┴──────────┤▒▒
▒▒│Descrićģo │ Elimina pedidos de campra com residuo                      │▒▒
▒▒├──────────┼────────────────────────────────────────────────────────────┤▒▒
▒▒│ Uso      │ Compras                                                    │▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
/*/

SetPrvt("CPROG1,AROTINA,CCADASTRO")

wEmiIni:=Ctod("  /  /  ")
wEmiFin:=Ctod("  /  /  ")
@ 0,0 TO 120,210 DIALOG oDlg5 TITLE "Elimina Pedidos de Compra com resĒduo"
@ 3,5 TO 35,100

@ 12,14 SAY "Emissao Inicial : "
@ 22,14 SAY "Emissao Final   : "

@ 12,60 GET  wEmiIni   SIZE 40,20 PICTURE X3Picture("C7_Emissao")  VALID NaoVazio()
@ 22,60 GET  wEmiFin   SIZE 40,20 PICTURE X3Picture("C7_Emissao")  VALID NaoVazio()

@ 40,40 BMPBUTTON TYPE 1 ACTION OkProc1()// Substituido pelo assistente de conversao do AP6 IDE em 23/03/04 ==> @ 105,155 BMPBUTTON TYPE 1 ACTION Execute(OkProc2)
@ 40,70 BMPBUTTON TYPE 2 ACTION Close(oDlg5)
ACTIVATE DIALOG oDlg5 CENTER

Return

****************
// Substituido pelo assistente de conversao do AP6 IDE em 23/03/04 ==> Function OkProc2
Static Function OkProc1()
****************
Close(oDlg5)

DbSelectArea("SC7")
DbSetOrder(5) // C7_EMISSAO
Dbgotop()
DbSeek(xFilial("SC7")+Dtos(WEmiIni),.T.)
While !EOF() .AND. C7_EMISSAO <= WEmiFin
  If C7_RESIDUO="S" .and. C7_QUJE<>0
     Reclock("SC7",.F.)
     C7_QUANT:=C7_QUJE
     C7_RESIDUO:=" "
     Dbunlock()     
  Endif
  If C7_RESIDUO="S" .and. C7_QUJE=0
     Reclock("SC7",.F.)
     SC7->( DBDELETE( ) )
     Dbunlock()
  Endif
  DbSkip()
End
Return
