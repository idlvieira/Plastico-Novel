User Function M103DSE2        

Local c_Alias, n_Ord, n_Reg, c_ForIcms, c_LojIcms, c_Doc

If SF1->F1_ICMSRET <=0
   Return
EndIf	

c_Alias := Alias()
n_Ord	:= DbSetOrder()
n_Reg	:= Recno()

c_Doc     := SF1->F1_DOC
c_ForIcms := Alltrim(GETMV("MV_RECEST"))+" "
c_LojIcms := "00"

dbSelectArea("SE2")
dbSetOrder(1)
dbSeek(xFilial("SE2")+"ICM"+c_Doc+"   "+"ICM"+c_ForIcms+c_LojIcms,.F.)

If SE2->( Found() )=.T. .and. SE2->E2_SALDO = SE2->E2_VALOR
   RecLock("SE2",.F.)
   SE2->( DbDelete() )
   SE2->( MsUnLock())              
EndIf

dbSelectArea(c_Alias)
dbSetOrder(n_Ord)
dbGoTo(n_Reg)
    
Return