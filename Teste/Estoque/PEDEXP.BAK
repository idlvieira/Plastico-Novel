▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒┌──────────┬──────────┬───────┬───────────────────────┬──────┬──────────┐▒▒
▒▒│Funcao    │ PEDEXP   │ Autor │ Eliene Cerqueira      │ Data │ 09.02.05 │▒▒
▒▒├──────────┼──────────┴───────┴───────────────────────┴──────┴──────────┤▒▒
▒▒│Descricao │Relacao dos Pedidos Liberados para Faturamento/ExpedińŃo    │▒▒
▒▒├──────────┼────────────────────────────────────────────────────────────┤▒▒
*/

User Function PEDEXP
//┌──────────────────────────────────────────────────────────────┐
//│ Define Variaveis                                             │
//└──────────────────────────────────────────────────────────────┘

wnrel  	:= "PEDEXP"    
titulo 	:= "Relacao de Pedidos de Vendas Liberados para Faturamento/ExpedińŃo"
cDesc1 	:= "Este programa ira emitir a relacao dos Pedidos de Vendas"
cDesc2 	:= "liberados para Faturamento/ExpedińŃo."
cDesc3 	:= ""
tamanho	:= "G"
limite 	:= 220
cString 	:= "SC6"
lEnd      := .F.
cabec1 	 := "  ITEM  PRODUTO            DESCRICAO                               QUANTIDADE     ENTREGA     POSICAO" 
cabec2 	 := ""
lContinua  := .T.
nTipo		 := GetMv("MV_COMP")
LI       := 80
m_pag      := 1
nLastKey := 0
IMP:=.F.
XSTATUS:=" "
xStatusIT:=" "
XQUANT:=0
PRIVATE aReturn  := { "Zebrado", 1,"Administracao", 1, 2, 1, "",1 }		//"Zebrado"###"Administracao"

//wnrel:=SetPrint(cString,wnrel,cPerg,titulo,cDesc1,cDesc2,cDesc3,.F.,aOrd,.T.,Tamanho)
wnrel:=SetPrint("",wnrel,,titulo,cDesc1,cDesc2,cDesc3,.F.,,.T.,Tamanho)

If nLastKey == 27
	Set Filter to
	Return
Endif

SetDefault(aReturn,cString)

If nLastKey==27
	Set Filter to
	Return
Endif

RptStatus({|lEnd| C700Imp(@lEnd,wnrel,cString,aReturn,tamanho,limite,;	
						  titulo,cDesc1,cDesc2,cDesc3)},Titulo)

DbSelectArea("EXP")
dbCloseArea()
Return 

Static Function C700Imp(lEnd,WnRel,cString,aReturn,tamanho,limite,titulo,;
						cDesc1,cDesc2,cDesc3)

cQry := " SELECT SC5.C5_NUM, SC5.C5_CLIENTE, SA1.A1_NREDUZ, SC5.C5_TPFRETE, SC5.C5_CIF_ATE, SC5.C5_EMISSAO," 
cQry := cQry + " SC5.C5_NOVULT, SC6.C6_ITEM, SC6.C6_PRODUTO, SB1.B1_DESC, SC6.C6_ENCOMED, SC6.C6_QTDVEN,"
cQry := cQry + " SC6.C6_QTDENT, SC6.C6_ENTREG, SC5.C5_MUNE, SC5.C5_ESTE, SC5.C5_CONDPAG, SC5.C5_TRANSP,"
cQry := cQry + " SC5.C5_OBS1, SC5.C5_OBS2, SC5.C5_OBS3, SC5.C5_VOLUME1, SC5.C5_ESPECI1, SA4.A4_NREDUZ, SE4.E4_DESCRI"
cQry := cQry + " FROM DB2ADMIN.SC5010 AS SC5, DB2ADMIN.SC6010 AS SC6, DB2ADMIN.SA1010 AS SA1, DB2ADMIN.SB1010 AS SB1, DB2ADMIN.SA4010 AS SA4, DB2ADMIN.SE4010 AS SE4"
cQry := cQry + " WHERE SC5.C5_NUM = SC6.C6_NUM"
cQry := cQry + " AND SA1.A1_COD = SC5.C5_CLIENTE"
cQry := cQry + " AND SA1.A1_LOJA = SC5.C5_LOJACLI" 
cQry := cQry + " AND SB1.B1_COD = SC6.C6_PRODUTO" 
cQry := cQry + " AND SA4.A4_COD = SC5.C5_TRANSP" 
cQry := cQry + " AND SE4.E4_CODIGO = SC5.C5_CONDPAG" 
cQry := cQry + " AND SC5.C5_TIPO = 'N'"
cQry := cQry + " AND SC6.C6_TES NOT  IN ('508', '515', '516', '517', '521', '522', '523', '524', '528', '529', '531', '536', '537', '543', '544', '545', '546', '547', '548', '549', '550', '555', '556', '557')"
cQry := cQry + " AND SC6.D_E_L_E_T_<>'*'"
cQry := cQry + " AND SC5.D_E_L_E_T_<>'*'"
cQry := cQry + " ORDER BY SC6.C6_ENTREG, SC5.C5_NUM, SC6.C6_ITEM ASC"
//AADD( aStru, {"STATUS"  ,"C" ,1 ,0} ) // Parcial, Total ou Branco
//AADD( aStru, {"STATUS"  ,"C" ,1 ,0} ) // 1-Liberado   2-Bloqueado    3-Faturado

Tcquery cQry new alias "EXP"

dbSelectArea("EXP")
SetRegua(RecCount())

While !EOF()

  IncRegua()
  If lAbortPrint
   	  @LI,00 PSAY "*** CANCELADO PELO OPERADOR ***"
      Exit
  Endif 

  IMP:=.F.
  xStatus:="T"
  XPED    :=EXP->C5_NUM
  XCLI    :=EXP->C5_CLIENTE
  XNOME   :=EXP->A1_NREDUZ
  XCID    :=EXP->C5_MUNE
  XUF     :=EXP->C5_ESTE
  XEMISSAO:=SUBSTR(EXP->C5_EMISSAO,7,2)+"/"+SUBSTR(EXP->C5_EMISSAO,5,2)+"/"+SUBSTR(EXP->C5_EMISSAO,3,2)
  XTPF    :=EXP->C5_TPFRETE
  XATE    :=EXP->C5_CIF_ATE
  XCPG    :=EXP->E4_DESCRI
  XVOL    :=EXP->C5_VOLUME1
  XESP    :=EXP->C5_ESPECI1
  XTRAN   :=EXP->C5_TRANSP
  XNTRAN  :=EXP->A4_NREDUZ
  XOBS    :=ALLTRIM(EXP->C5_OBS1)+" "+ALLTRIM(EXP->C5_OBS2)+" "+ALLTRIM(EXP->C5_OBS3)
  XLIB    :=SUBSTR(EXP->C5_NOVULT,7,2)+"/"+SUBSTR(EXP->C5_NOVULT,5,2)+"/"+SUBSTR(EXP->C5_NOVULT,3,2)
  ITEM := {}
  PROD := {}
  DESC := {}
  QTDE := {}
  ENTR := {}
  XSTA := {}
  While !EOF() .AND. EXP->C5_NUM=XPED
     TSTXSTA()
     DbSelectArea("EXP") 
     dbSkip()
  Enddo   
  DbSelectArea("EXP") 
  If !IMP
   	 Loop
  Endif                                          
 
  If LI > 68
     Cabec(Titulo,Cabec1,Cabec2,wnrel,Tamanho,nTipo)
  Endif   
  @ LI,02       PSAY "PEDIDO: "+XPED
  @ LI,PCol()+2 PSAY "CLIENTE: "+XCLI+"-"+XNOME+"/"+XCID+"-"+XUF
  @ LI,80       PSAY "EMISSAO: "+XEMISSAO
  @ LI,PCol()+2 PSAY "STATUS: "+IIF(xstatus="P","PARCIAL","TOTAL  ")
  @ LI,PCol()+2 PSAY "FRETE/SEGURO: "+IIF(XTPF="C","CIF ate "+AllTrim(XATE),"FOB")
  @ LI,162      PSAY "COND.PGTO: "+XCPG
  @ LI,PCol()+2 PSAY "QTD.: "
  @ LI,PCol()+2 PSAY XVOL Picture "@E 99,999"
  @ LI,PCol()+1 PSAY XESP
  LI := LI + 1
  @ LI,02       PSAY "TRANSP.: "+XTRAN+" "+XNTRAN
  @ LI,PCol()+1 PSAY "OBSERVACOES: "+XOBS
  @ LI,195      PSAY "LIBERAŪ├O: "+XLIB
  LI := LI + 1

  For I:=1 to Len(ITEM)
     If LI > 68
        Cabec(Titulo,Cabec1,Cabec2,wnrel,Tamanho,nTipo)
     Endif   
     @ LI,02       PSAY ITEM[I]
     @ LI,PCol()+3 PSAY PROD[I]
     @ LI,PCol()+5 PSAY DESC[I]
     @ LI,PCol()+1 PSAY QTDE[I] Picture "@E 999,999.99"
     @ LI,PCol()+4 PSAY ENTR[I]
     If XSTA[I]="1"
        @ LI,PCol()+5 PSAY "LIBERADO"
     ElseIf XSTA[I]="2"
        @ LI,PCol()+5 PSAY "BLOQUEADO"
     Else
        @ LI,PCol()+5 PSAY "FATURADO"
     Endif
     LI := LI + 1
  Next
  LI := LI + 1
EndDo

@ LI,01 PSAY "."
SET DEVICE TO SCREEN

If aReturn[5]==1
	dbCommitAll()
	SET PRINTER TO
	OurSpool(wnrel)
Endif

MS_FLUSH()

Return
         
STATIC Function TSTXSTA()
  AADD(ITEM ,EXP->C6_ITEM)
  AADD(PROD ,EXP->C6_PRODUTO)
  AADD(DESC ,EXP->B1_DESC)
  AADD(ENTR ,SUBSTR(EXP->C6_ENTREG,7,2)+"/"+SUBSTR(EXP->C6_ENTREG,5,2)+"/"+SUBSTR(EXP->C6_ENTREG,3,2))
  If EXP->C6_QTDVEN-EXP->C6_QTDENT = 0
     AADD(XSTA ,"3")
     AADD(QTDE ,EXP->C6_QTDVEN)
  Else
     dbSelectArea("SC9")
     dbSetOrder(1)
     dbSeek(xFilial("SC9")+EXP->C5_NUM+EXP->C6_ITEM,.F.)
   
     If !Found()// Bloqueado em vendas
        xStatus:="P"        
        AADD(XSTA ,"2")
     Else
        While !EOF() .AND. EXP->C5_NUM=SC9->C9_PEDIDO .AND. EXP->C6_ITEM=SC9->C9_ITEM
           BLCRED:=C9_BLCRED               
           BLEST :=C9_BLEST
           DATLIB:=C9_DATALIB
           XQTD:=C9_QTDLIB
       	   dbSkip()
        Enddo
        AADD(QTDE ,XQTD)
        If BLCRED="10" .and. BLEST="10" // Jß faturado
           xStatus:="P"
           AADD(XSTA ,"3")
        ElseIf (BLCRED="01" .and. BLEST="02") .or. (BLCRED="01" .and. BLEST="  ") // Bloqueado no crķdito
           xStatus:="P"
           AADD(XSTA ,"2")
        ElseIf BLCRED="  " .and. BLEST="02" // Bloqueado no estoque
           xStatus:="P"
           AADD(XSTA ,"2")
        ElseIf BLCRED="  " .and. BLEST="  "
           AADD(XSTA ,"1")
           IMP:=.T.                    
        Endif
     Endif
  Endif

Return(NIL)
