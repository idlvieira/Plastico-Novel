Return


User Function CMEDd1()        // incluido pelo assistente de conversao do AP6 IDE em 20/04/04

SetPrvt("WCMED,WSEQ,")

wCmed:=SD1->D1_Custo/SD1->D1_Quant
wSeq :=SD1->D1_NumSeq
@ 0,0 TO 120,210 DIALOG oDlg1 TITLE "Troca Custo do Movimento"
@ 3,5 TO 35,100
// Montagem dos titulos dos campos
@ 12,10 say  "Sequencia "
@ 22,10 say  "Custo  "

// Montagem dos campos
@ 12,50      Say  wSeq    
@ 22,50      GET  wcMed   PICTURE "@E 9,999.9999" 

// Botoes
@  40,40 BMPBUTTON TYPE 1 ACTION CMEDOk1()// Substituido pelo assistente de conversao do AP6 IDE em 20/04/04 ==>     @  60,65 BMPBUTTON TYPE 1 ACTION Execute(BotOk1)
@  40,70 BMPBUTTON TYPE 2 ACTION CMEDCan1()// Substituido pelo assistente de conversao do AP6 IDE em 20/04/04 ==>     @  60,95 BMPBUTTON TYPE 2 ACTION Execute(BotCan1)
ACTIVATE DIALOG oDlg1 CENTER
REturn


// Substituido pelo assistente de conversao do AP6 IDE em 20/04/04 ==> Function BotOk1
Static Function CMEDOk1()
***************
Close(oDlg1)

Reclock("SD1",.F.)
SD1->D1_Custo:=VAL(STR((SD1->D1_Quant*wCmed),14,2))
Dbunlock()

Return

// Substituido pelo assistente de conversao do AP6 IDE em 20/04/04 ==> Function BotCan1
Static Function CMEDCan1()
***************
Close(oDlg1)
Return

User Function tesd1()        // incluido pelo assistente de conversao do AP6 IDE em 22/04/04

SetPrvt("XTES,XCFO,XCFOP,WTES,WCFO,WCFOP")
SetPrvt("WFILIAL,WICMS,")

wTes :=SD1->D1_Tes
wCfo :=SD1->D1_Cf
*wCfop:=SD1->D1_Cfop
wFilial:=xFilial()

@ 0,0 TO 200,210 DIALOG oDlg1 TITLE "Troca de TES"
@ 3,5 TO 70,100
// Montagem dos titulos dos campos
   @ 20,10 say  "TES Correta"
   @ 30,10 say  "CFO Correto"
   @ 40,10 say  "CFO Novo   "
// Montagem dos campos
   @ 20,60      GET  wTes   PICTURE X3Picture("F4_Codigo")  VALID NaoVazio() .and. ExistCpo("SF4")  F3 "SF4"
   @ 30,60      GET  wCfo   PICTURE "999"                   VALID NaoVazio() .and. ExistCpo("SX5","13"+wCfo)  F3 "SX5"
*   @ 40,60      GET  wCfop  PICTURE "9999"                  VALID NaoVazio()
// Botoes
   @ 75,40 BMPBUTTON TYPE 1 ACTION TesOk1()// Substituido pelo assistente de conversao do AP6 IDE em 22/04/04 ==>    @ 85,65 BMPBUTTON TYPE 1 ACTION Execute(BotOk1)
   @ 75,70 BMPBUTTON TYPE 2 ACTION TesCan1()// Substituido pelo assistente de conversao do AP6 IDE em 22/04/04 ==>    @ 85,95 BMPBUTTON TYPE 2 ACTION Execute(BotCan1)
   ACTIVATE DIALOG oDlg1 CENTER
Return

// Substituido pelo assistente de conversao do AP6 IDE em 22/04/04 ==> Function BotOk1
Static Function TesOk1()
***************
Close(oDlg1)

***> Verificando se TES possue ICMS
dbSelectArea("SF4")                // * Tipo de TES
dbSetOrder(1)
SF4->( DbSeek(wFilial+wTES,.F.) )
If  SF4->( Found() ) ==.T.
    wIcms:=SF4->F4_Icm
Else
    wIcms:=" "
Endif

Reclock("SD1",.F.)
SD1->D1_Tes :=wTes
SD1->D1_CF  :=wCfo
*SD1->D1_CFOP:=wCfop
If  wIcms=="N"
    SD1->D1_VALICM:=0
    SD1->D1_PICM  :=0
Endif
Dbunlock()

Return

// Substituido pelo assistente de conversao do AP6 IDE em 22/04/04 ==> Function BotCan1
Static Function TesCan1()
***************
Close(oDlg1)
Return
