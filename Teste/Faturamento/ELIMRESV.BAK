User Function residuo()        // incluido pelo assistente de conversao do AP6 IDE em 20/04/04

If !Empty(C5_NOTA)
   MsgBox("PEDIDO TOTALMENTE FATURADO!")
   Return
Endif
IF  MsgBox("A ELIMINAﾇﾃO DO RESﾍDUO DESTE REGISTRO PROVOCARA O FECHAMENTO TOTAL DESTE PEDIDO. CONFIRMA??","CONFIRMA ?","YESNO")
    delOK1()
ENDIF

REturn

// Substituido pelo assistente de conversao do AP6 IDE em 20/04/04 ==> Function BotOk1
Static Function delOk1()
***************
XNF:=SPACE(6)
XSER:=SPACE(3)
dbSelectArea("SC6")
dbSetOrder(1) // pedido+item
dbSeek(xFilial("SC6")+SC5->C5_NUM,.F.)	
While !EOF() .AND. SC6->C6_NUM=SC5->C5_NUM

    dbSelectArea("SC9")
    dbSetOrder(1)
    dbSeek(xFilial("SC9")+SC6->C6_NUM+SC6->C6_ITEM,.F.)
   
    If Found()
       While !EOF() .AND. SC6->C6_NUM=SC9->C9_PEDIDO .AND. SC6->C6_ITEM=SC9->C9_ITEM
          If !EMPTY(C9_NFISCAL)
             XNF:=C9_NFISCAL
             XSER:=C9_SERIENF
          Endif
     	  dbSkip()
       Enddo
       dbSkip(-1)
       If SC6->C6_QTDVEN-SC6->C6_QTDENT <> 0
          Reclock("SC9",.F.)
          SC9->( DBDELETE( ) )
          Dbunlock()
       Endif
    Endif
    dbSelectArea("SC6")
    If C6_QTDEMP=C6_QTDVEN
       Reclock("SC6",.F.)
       SC6->( DBDELETE( ) )
       Dbunlock()
    ElseIf SC6->C6_QTDVEN-SC6->C6_QTDENT <> 0
       Reclock("SC6",.F.)
       C6_QTDVEN:=C6_QTDENT
       C6_QTDEMP:=0
       C6_VALOR:=C6_QTDVEN*C6_PRCVEN
       Dbunlock()
    Endif
    dbSkip()
Enddo
If !EMPTY(XNF)
   Reclock("SC5",.F.)
   C5_NOTA:=XNF
   C5_SERIE:=XSER
   Dbunlock()
Endif
Return

// Substituido pelo assistente de conversao do AP6 IDE em 20/04/04 ==> Function BotOk1
Static Function nseqOk1()
***************
Close(oDlg1)

Reclock("SD1",.F.)
SD1->D1_NumSeq:=wSeq
Dbunlock()

Return


