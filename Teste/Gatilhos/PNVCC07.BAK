mqtdv:=acols[n][7]   //M->UB_QUANT
DbSelectArea("SUA")
If SUA->UA_STATUS="LIB"
   msgBox("Pedido Liberado, Alteração, Não Permitida!!!")
   mqtdv := 0.00
endif

return(mqtdv)