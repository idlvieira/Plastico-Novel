&& Imprime o Cabecalho
Static Function fImpCabec(cTitulo,nPagina,lPula,lImpd,lPriVez)

	If lPula
		If	!lPriVez
			oPrint:EndPage()
		EndIf
		oPrint:StartPage()
		nLinha := 0010
		nPagina++
		oPrint:Box(nLinha,nColIni,nLinha + 110,nColFim)		&& Tamanho total do quadro em Landscape
		oPrint:Say(nLinha + 12, nColFim/2 	,"FATURAMENTO MENSAL NOVEL-BA",oFont14b,,CLR_BLUE,,PAE_CENTER)
		oPrint:Say(nLinha + 72, nColFim/2 	,"Perэodo de Emissуo das Notas Fiscais - De: "+Dtoc(mv_par01)+" - Atщ "+Dtoc(mv_par02),oFont10b,,CLR_BLUE,,PAE_CENTER)
		OPrint:Say(nLinha + 72, nColFim-30  ,"Pсgina: "+Strzero(nPagina,3),oFont10b,,CLR_BLUE,,PAE_RIGHT)
		nLinha += 120
	EndIf
	
	If lImpD
		oPrint:Box(nLinha,nColIni,nLinha + 60,nColFim)		&& Tamanho total do quadro em Landscape
		Imprev(nLinha,nLinha + 60)
		nLinha +=025
		oPrint:Say(nLinha ,0025 ,"N.F. / Serie"	,oFont08b,,CLR_BLACK,,PAE_LEFT)
		oPrint:Say(nLinha ,0280 ,"Data"       		,oFont08b,,CLR_BLACK,,PAE_CENTER)
		oPrint:Say(nLinha ,0380 ,"Cliente"			,oFont08b,,CLR_BLACK,,PAE_LEFT)
		oPrint:Say(nLinha ,1000 ,"P/N"				,oFont08b,,CLR_BLACK,,PAE_CENTER)
		oPrint:Say(nLinha ,1250 ,"Qtd."				,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,1400 ,"Vl.Unit."			,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,1600 ,"Vl.Total"			,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,1800 ,"IPI"				,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,2000 ,"ICMS"				,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,2200 ,"PIS/Cofins"		,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,2450 ,"Total NF"			,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,2700 ,"Total Liquido R$"	,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,2900 ,"CUSTO"			,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,3100 ,"% MARGEM"			,oFont08b,,CLR_BLACK,,PAE_RIGHT)
		oPrint:Say(nLinha ,3170 ,"GRUPO"			,oFont08b,,CLR_BLACK,,PAE_LEFT)
		nLinha +=050
	EndIf

Return .T.

&&
Static Function fImpDet()

	If nLinha > 2300
		fImpCabec(cTitulo,@nPagina,.T.,.T.)
	EndIf
	oPrint:Box(nLinha-2,nColIni,nLinha + 35,nColFim)		&& Tamanho total do quadro em Landscape
	Imprev(nLinha-2,nLinha + 35)
	nLinha +=004
	oPrint:Say(nLinha ,0025 ,&cArray[nPos][01]+"/"+&cArray[nPos][18]			,oFont08,,CLR_BLACK,,PAE_LEFT)
	oPrint:Say(nLinha ,0280 ,DtoC(&cArray[nPos][02])      						,oFont08,,CLR_BLACK,,PAE_CENTER)
	oPrint:Say(nLinha ,0380 ,&cArray[nPos][03]									,oFont08,,CLR_BLACK,,PAE_LEFT)
	oPrint:Say(nLinha ,1000 ,&cArray[nPos][04]									,oFont08,,CLR_BLACK,,PAE_CENTER)
	oPrint:Say(nLinha ,1250 ,Transform(&cArray[nPos][06],"@E 999,999.99")		,oFont08,,CLR_BLACK,,PAE_RIGHT)
	oPrint:Say(nLinha ,1400 ,Transform(&cArray[nPos][07],"@E 999,999.99")		,oFont08,,CLR_BLACK,,PAE_RIGHT)
	oPrint:Say(nLinha ,1600 ,Transform(&cArray[nPos][08],"@E 999,999,999.99")	,oFont08,,CLR_BLACK,,PAE_RIGHT)
	oPrint:Say(nLinha ,1800 ,Transform(&cArray[nPos][09],"@E 9,999,999.99")	,oFont08,,CLR_BLACK,,PAE_RIGHT)
	oPrint:Say(nLinha ,2000 ,Transform(&cArray[nPos][10],"@E 9,999,999.99")	,oFont08,,CLR_BLACK,,PAE_RIGHT)
	oPrint:Say(nLinha ,2200 ,Transform(&cArray[nPos][11],"@E 9,999,999.99")	,oFont08,,CLR_BLACK,,PAE_RIGHT)
	oPrint:Say(nLinha ,2450 ,Transform(&cArray[nPos][12],"@E 999,999,999.99")	,oFont08,,CLR_BLACK,,PAE_RIGHT)
