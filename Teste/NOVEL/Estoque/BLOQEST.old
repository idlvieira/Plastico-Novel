Static Function Bloq()        // incluido pelo assistente de conversao do AP6 IDE em 20/04/04

wQtdLib:=0
dbSelectArea("TRB")
DbGoTop()
Do While !EOF()
      
   If MARCA<>cMarca
   	  dbSkip()
	  Loop
   Endif
   wQtdLib :=wQtdLib+TRB->QUANT
   DbSkip()
End

@ 0,0 TO 100,430 DIALOG oDlg2
@ 3,5 TO 30,210
@ 15,010 SAY "Saldo Liberado : "  + Transform(wQtdLib,"@E 999,999.99")
@ 38,070 BMPBUTTON TYPE 1 ACTION Ok1()// Substituido pelo assistente de conversao do AP6 IDE em 20/04/04 ==>     @  60,65 BMPBUTTON TYPE 1 ACTION Execute(BotOk1)
@ 38,100 BMPBUTTON TYPE 2 ACTION Can1()// Substituido pelo assistente de conversao do AP6 IDE em 20/04/04 ==>     @  60,95 BMPBUTTON TYPE 2 ACTION Execute(BotCan1)
ACTIVATE DIALOG oDlg2 CENTER

Close(oDlg7)
Return

Static Function Ok1()

XRES:=0
dbSelectArea("TRB")
dbGoTop()
While !EOF()

   If MARCA<>cMarca
      XRES:=XRES+TRB->QUANT
   	  dbSkip()
	  Loop
   Endif

   dbSelectArea("SC9")
   dbSetOrder(1)
   dbGoTop()
   dbSeek(xFilial("SC9")+TRB->PEDIDO+TRB->ITEM,.F.)
   If !Found()
      dbSelectArea("TRB")
   	  dbSkip()
      Loop
   Else
      While !EOF() .AND. SC9->C9_PEDIDO=TRB->PEDIDO .AND. SC9->C9_ITEM=TRB->ITEM
     	  dbSkip()
      Enddo
      dbSkip(-1)
      Reclock("SC9",.F.)
      C9_BLCRED  := "  "
      C9_BLEST  := "02"
      MSUnlock()
      dbSelectArea("TRB")
      dbSkip()
   Endif
Enddo

dbSelectArea("SB2")
Reclock("SB2",.F.)
B2_RESERVA  := XRES
B2_QACLASS := 0
MSUnlock()
DbselectArea("TRB")
DbCloseArea("TRB")
FErase( cArqTrb1+".*")
Close(oDlg2)
Return

Static Function Can1()
DbselectArea("TRB")
DbCloseArea("TRB")
FErase( cArqTrb1+".*")
Close(oDlg2)
Return

Static Function Fecha()

XRES:=0
dbSelectArea("TRB")
dbGoTop()
While !EOF()
   If MARCA<>cMarca
      XRES:=XRES+TRB->QUANT
   Endif
   dbSkip()
Enddo

dbSelectArea("SB2")
Reclock("SB2",.F.)
B2_RESERVA  := XRES
B2_QACLASS := 0
MSUnlock()

DbCloseArea("TRB")
FErase( cArqTrb1+".*")
Close(oDlg7)
Return
