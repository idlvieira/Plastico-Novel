#INCLUDE "rwmake.ch" 

User Function mudasd1x

dbSelectArea("SD1")
dbgotop()

wProd:=Space(15)
wTipo:=space(2)

While !EOF()
    
    wProd:= SD2->D2_COD 
    
    dbSelectArea("SB1") 
    DbSeek(xFilial("SB1") + wProd, .T.)
    If found()   
         wTipo:= SB1->B1_TIPO
         dbSelectArea("SD1")
         RecLock("SD1",.f.)
         REPLACE SD1->D1_tipo with "XX"
         MSUNLOCK()
    endif

    dbSelectArea("SD1")
    Dbskip()
enddo  

return