METHOD FECHATXT() CLASS GRVTXT
  Local lRet := .T.

  If !(fClose(::cFile))
    lRet := .F.
    Alert("Erro ao fechar o arquivo "+ ::cNameArq +"." )
    Conout("Erro ao fechar o arquivo "+ ::cNameArq +"." )
  Endif  
RETURN lRet