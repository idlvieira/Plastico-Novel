#IFDEF WINDOWS
	RptStatus({|| RptDetail()})// Substituido pelo assistente de conversao do AP5 IDE em 10/05/02 ==> 	RptStatus({|| Execute(RptDetail)})
	Return
// Substituido pelo assistente de conversao do AP5 IDE em 10/05/02 ==> 	Function RptDetail

Static Function RptDetail()
#ENDIF

Limite:=132
Tamanho:="M"
@ 0,0 PSay AvalImp(limite)

If mv_par03 <> "SRV"
        MsgBox("Erro na opcao de parametros : Serie <> SRV","Serie Invalida","STOP")
	Return
EndIf

If LastKey() == 27 
	Return
Endif

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
