//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Inicio da Funcao    ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

// Substituido pelo assistente de conversao do AP5 IDE em 10/05/02 ==> Function IMPDET
Static Function IMPDET()

xTamDet := 25
I2  := 1
I   := 1

For I := 1 to xTamDet
	  
	  If I2 <= Len( xITEM_PED )

	 @ Linha, 002 PSay xDESC_PRO[I]
	 @ Linha, 070 PSay xQTD_PRO[I]              Picture "@E@Z 99,999.99"
	 @ Linha, 087 PSay xPRE_UNI[I]              Picture "@E@Z 99,999.99"
	 @ Linha, 108 PSay xVAL_MERC[I]             Picture "@E@Z 99,999.99"

	  EndIf  
	 
	  Linha := Linha + 1
	  I2 := I2 + 1 

Next

Return

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
