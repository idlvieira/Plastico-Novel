//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

VerImp()

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ                                                              ｳ
//ｳ Inicio do Processamento da Nota Fiscal                       ｳ
//ｳ                                                              ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Guarda Empresa que esta sendo emitido nota fiscal            ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ


dbSelectArea("SF2")                // * Cabecalho da Nota Fiscal

xCOD_FIL  := SM0->M0_CODIGO
xNOME_FIL := SM0->M0_FILIAL

dbSelectArea("SF2")                // * Cabecalho da Nota Fiscal
dbSetOrder(1)  
dbGoTop()
dbSeek(xFilial()+mv_par01+mv_par03,.t.)

	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳ Inicializa  regua de impressao                            ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	SetRegua(Val(mv_par02)-Val(mv_par01))
	

While !eof() .and. SF2->F2_DOC  <= mv_par02 .and. lContinua == .T.

 If SF2->F2_SERIE  == mv_par03    // Verifica se a nota e de servico

		nLinIni := Linha            // Armazema Linha Inicial da Impressao

	#IFNDEF WINDOWS
	      IF LastKey()==286
		      @ 00,01 PSAY "** CANCELADO PELO OPERADOR **"
	     	      lContinua := .F.
	              Exit
	      Endif
	#ELSE
 	      IF lAbortPrint
		      @ 00,01 PSAY "** CANCELADO PELO OPERADOR **"
		      lContinua := .F.
		      Exit
	      Endif
	#ENDIF


	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳ Inicio de Levantamento dos Dados da Nota Fiscal              ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	
	// Cabecalho da Nota Fiscal

	  
	xNUM_NF     := SF2->F2_DOC             // Numero
	xSERIE      := SF2->F2_SERIE           // Serie
	xEMISSAO    := SF2->F2_EMISSAO         // Data de Emissao
	xTOT_FAT    := SF2->F2_VALFAT          // Valor Total da Fatura
	xTIPONF     := SF2->F2_TIPO            // Tipo da Nota Fiscal
	xLOJA       := SF2->F2_LOJA            // Loja do Cliente
	xVALOR_MERC := SF2->F2_VALMERC         // Valor  da Mercadoria
	xNUM_DUPLIC := SF2->F2_DUPL            // Numero da Duplicata
	xCOND_PAG   := SF2->F2_COND            // Condicao de Pagamento
	xTIPO       := SF2->F2_TIPO            // Tipo do Cliente
	xBASE_ISS   := SF2->F2_BASEISS         // Base de ISS
//	xVALOR_ISS  := xBASE_ISS * (3/100)
	xVALOR_ISS  := SF2->F2_VALISS
	
	dbSelectArea("SD2")                // * Itens de Venda da Nota Fiscal
	dbSetOrder(3)
	dbSeek(xFilial()+xNUM_NF+xSERIE)
	
	xPED_VEND   := {}                         // Numero do Pedido de Venda
	xITEM_PED   := {}                         // Numero do Item do Pedido de Venda
	xNUM_NFDV   := {}                         // Numero quando houver devolucao
	xPREF_DV    := {}                         // Serie  quando houver devolucao
	xCOD_PRO    := {}                         // Codigo  do Produto
	xQTD_PRO    := {}                         // Peso/Quantidade do Produto
	xPRE_UNI    := {}                         // Preco Unitario de Venda
	xDESC       := {}                         // Desconto por Item
	xVAL_DESC   := {}                         // Valor do Desconto
	xVAL_MERC   := {}                         // Valor da Mercadoria
	xTES        := {}                         // TES
	xCF         := {}                         // Classificacao quanto natureza da Operacao

	xNatureza   := {}
	xCfop1      := {}
	xDesc_Total := 0

	While !eof() .and. SD2->D2_DOC == xNUM_NF .and. D2_SERIE == mv_par03

		AADD(xITEM_PED ,SD2->D2_ITEMPV)
		AADD(xPED_VEND ,SD2->D2_PEDIDO)
		AADD(xPREF_DV  ,SD2->D2_SERIORI)
		AADD(xCOD_PRO  ,SD2->D2_COD)
		AADD(xQTD_PRO  ,SD2->D2_QUANT)
		AADD(xPRE_UNI  ,SD2->D2_PRCVEN)
		AADD(xDESC     ,SD2->D2_DESC)
		AADD(xVAL_MERC ,SD2->D2_TOTAL)
		AADD(xTES      ,SD2->D2_TES)
		AADD(xCF       ,SD2->D2_CF)
		xCFOP  := xCF[Len(xCF)]
		
		dbskip()
	
	End

	dbSelectArea("SB1")                // * Descricao Generica do Produto
	dbSetOrder(1)
	xCOD_TRIB := {}                           // Codigo de Tributacao
	xCOD_FIS  := {}                           // Cogigo Fiscal
	xCLAS_FIS := {}                           // Classificacao Fiscal
	xISS      := {}                           // Aliquota de ISS
	xTIPO_PRO := {}                           // Tipo do Produto
	
	I:=1
	xPos:=0
	
	For xContador := 1 To Len( xCod_Pro )
	
		 dbSeek(xFilial()+xCOD_PRO[xContador])
	
		 AADD(xCOD_TRIB ,SB1->B1_ORIGEM)
		 AADD(xCOD_FIS  ,SB1->B1_CLASFIS)
		 AADD(xISS      ,SB1->B1_ALIQISS)

	Next
	
	
	dbSelectArea("SC5")                // * Pedidos de Venda
	dbSetOrder(1)
	
	xPED:={}
	Achou := .F.

	For xContador := 1 To Len( xPed_Vend )
	
		 If !Achou
		 
			 dbSeek(xFilial()+xPED_VEND[xContador])
	
			 xDATA_PED   :=SC5->C5_EMISSAO            // Data de Emissao do pedido
			 xCLIENTE    :=SC5->C5_CLIENTE            // Codigo do Cliente
			 xTIPO_CLI   :=SC5->C5_TIPOCLI            // Tipo de Cliente
			 xCONDPAG    :=SC5->C5_CONDPAG            // Condicao de Pagamento
			 xDESC_NF := {SC5->C5_DESC1,;             // Desconto Global 1
				 SC5->C5_DESC2,;             // Desconto Global 2
				 SC5->C5_DESC3,;             // Desconto Global 3
				 SC5->C5_DESC4}              // Desconto Global 4
			 Achou := .T.

		 EndIf

		 AADD(xPED,xPED_VEND[I])

	Next


	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳ Pesquisa da Condicao de Pagto               ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

	dbSelectArea("SE4")
	dbSetOrder(1)
	dbSeek( xFilial() + xCONDPAG )
	xDESC_PAG := SE4->E4_DESCRI

	dbSelectArea("SC6")                    // * Itens de Pedido de Venda
	dbSetOrder(1)
	xDESC_PRO := {}                          // Descricao aux do produto
	J:= Len(xPED_VEND)
	For I:= 1 to J
		 dbSeek(xFilial()+xPED_VEND[I]+xITEM_PED[I])
		 AADD(xDESC_PRO,SC6->C6_DESCRI)
		 xDESC_TOTAL := xDESC_TOTAL + SC6->C6_VALDESC
	Next
	
	If xTIPO$"NVPCI"
		
		dbSelectArea("SA1")                // * Cadastro de Clientes
		dbSetOrder(1)
		dbSeek(xFilial()+xCLIENTE)
		xNOME_CLI := SA1->A1_NOME               // Nome
		xEND_CLI  := SA1->A1_END                // Endereco
		xTIPO     := SA1->A1_TIPO               // Tipo
		xSUFRAMA  := SA1->A1_CALCSUF            // Se e Suframdo
		xBAIRRO   := SA1->A1_BAIRRO             // Bairro
		xBR_CLI   := SA1->A1_BAIRROC            // Bairro Cobranca
		xCEP      := SA1->A1_CEP                // CEP
		xCEPPAG   := SA1->A1_CEPC               // Cep Cobr. CLiente
		xCOB_CLI  := SA1->A1_ENDCOB             // Endereco de Cobranca
		xREC_CLI  := SA1->A1_ENDENT             // Endereco de Entrega
		xMUN_CLI  := SA1->A1_MUN                // Municipio
		xEST_CLI  := SA1->A1_EST                // Estado
		xCGC_CLI  := SA1->A1_CGC                // CGC
		xINSC_CLI := SA1->A1_INSCR              // Inscricao estadual
		xTRAN_CLI := SA1->A1_TRANSP             // Transportadora
		xTEL      := SA1->A1_TEL                // Telefone
		xFAX      := SA1->A1_FAX 
		xCIPAG    := SA1->A1_MUNPAG             // Municipio de pagamento
		xMARCA    := SA1->A1_MARCA              // Abreviacao do Nome Reduzido, Criado
														  // a Partir de Solicitacao do Usuario.

	Endif

	dbSelectArea("SE1")                // * Contas a Receber
	dbSetOrder(1)
	
	xVENC_DUP  :={}                      // Vencimento
	xVALOR_DUP :={}                      // Valor
	xDUPLICATAS:=IIF(dbSeek(xFilial()+xSERIE+xNUM_DUPLIC,.T.),.T.,.F.) // Flag p/Impressao de Duplicatas
	
	while !eof() .and. SE1->E1_NUM == xNUM_DUPLIC .and. xDUPLICATAS==.T. ;
			  .and. SE1->E1_PREFIXO == mv_par03

		AADD(xVENC_DUP ,SE1->E1_VENCTO)
		AADD(xVALOR_DUP,SE1->E1_VALOR)
		dbSkip()
	End

	dbSelectArea("SF4")                // * Tipos de Entrada e Saida
	dbSetOrder(1)

	For xContador := 1 To Len( xTes )
		 
		 DbSelectArea("SF4")
		 DbSetOrder(1)
	
		 dbSeek(xFilial()+xTES[xContador])
	
		 Aadd(xNATUREZA,SF4->F4_TEXTO)  // Natureza da Operacao
	
		 DbSelectArea("SD2")
		 DbSetOrder(3)
		 DbSeek(xFilial("SD2")+xNUM_NF+xSERIE+xCF[xContador])
		 Aadd(xCFOP1,xCF[xContador])

	Next

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ                                                              ｳ
//ｳ                         IMPRESSAO                            ｳ
//ｳ                                                              ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	
		//Compactacao da Impressora Para Impressao do Cabecalho

	@ linha, 000 PSay chr(15)

	 //ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	 //ｳ  Fator := { 0.2 x [ 6/2 ] } + ( 50 - 40 )                    ｳ
	 //ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

		  linha := linha + 1
		  @ linha, 117 PSay xVALOR_MERC   Picture "@E@Z 99,999,999.99"

                  linha := linha + 10

	 //ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	 //ｳ Estas Condicoes Abaixo, sao Para a Impressao de Varios Tes   ｳ
	 //ｳ Numa Unica Nota de Saida.                                    ｳ
	 //ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		 
	Coluna  := 2
	xBarra  := ""
	xUltima := ""
	
	For xContador := 1 To Len( xNatureza )

		 If xUltima <> xNatureza[xContador]

			 @ linha, Coluna PSay xBarra + AllTrim(SubStr(xNATUREZA[xContador],1,10))
			 Coluna  := Coluna + Len( SubStr(xNatureza[xContador] ,1,10) )
			 xBarra  := "/"
			 xUltima := xNatureza[xContador]

		 EndIf
						
	Next

	Linha := Linha + 3
	
	@ linha, 002 PSay xNOME_CLI
	
	If !Empty(xCGC_CLI)
		@ linha, 090 PSay xCGC_CLI Picture "@R 99.999.999/9999-99" // Linha 15
	EndIf
	
	@ linha, 124 PSay xEMISSAO                                    // Linha 15
	
	linha:=Linha + 2
	@ linha, 002 PSay xEND_CLI   // 17
	@ linha, 070 PSay xBAIRRO    // 17
	
	If !Empty(xCEP)
		@ linha, 101 PSay xCEP Picture "@R 99999-999" // 17
	EndIf
	
	linha := linha + 2
	@ linha, 002 PSay xMUN_CLI     //19
	@ linha, 050 PSay ALLTRIM(xTEL) + " / " + xFAX 
	@ linha, 080 PSay xEST_CLI     //19
	@ linha, 088 PSay xINSC_CLI    //19
	@ linha, 124 PSay Time()       //19

	linha := linha + 3
	
	// DEVERAO SER INPRESSAS AS PARCELAS DAS DUPLICATAS

	x := 1
	BB:= 1

	For x := 1 to 2

		 nCol := 22
		 DUPLIC()
		 nCol := 60
		 DUPLIC()
		 nCol := 101
		 DUPLIC()
		 
		 linha := linha + 1

	Next
	
	linha := linha + 1

	@ linha, 002 PSay ALLTRIM(xCOB_CLI) + " " + ALLTRIM(xBR_CLI) 
	Linha := Linha + 1
	@ linha, 002 PSay xCEPPAG PICTURE "@R 99999-999" 
	@ Linha, 012 PSay ALLTRIM(xCIPAG) + "-" + ALLTRIM(xEST_CLI)
	linha := linha + 5

	ImpDet()
	 
//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Testa se Houve Desconto nos Itens da Nota.                   ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

	linha := linha + 1
	
	@ linha, 005 PSay xBASE_ISS  Picture "@E@Z 9,999,999.99"
	@ Linha, 046 PSay xVALOR_ISS*100/xBASE_ISS "@E 9"
	@ Linha, 047 PSay "%" 
	@ linha, 062 PSay xVALOR_ISS Picture "@E@Z 9,999,999.99"
	@ Linha, 098 PSay xVALOR_MERC   Picture "@E@Z 99,999,999.99"
	  
  //ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
  //ｳ Termino da Impressao da Nota Fiscal                          ｳ
  //ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	
	Linha := Linha + 11
 
 EndIf 

	dbSelectArea("SF2")     //
	dbSetOrder(1)           // Reestabelece Area Principal de Pesquisa
	dbSkip()                // e passa para a proxima Nota Fiscal
	Incregua()
End


//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
