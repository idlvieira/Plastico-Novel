/*/

Static Function IMPMENP
					  
nCol:= 003
Linha := Linha + 1
@ Linha, 0 PSay PADC(UPPER(xDESC_PAG),55)

Linha := Linha + 1

@ Linha   , 0 PSay PADC(UPPER(XDESCR1),80)
@ Linha+01, 0 PSay PADC(UPPER(XDESCR2),80)
@ Linha+02, 0 PSay PADC(UPPER(XDESCR3),80)
@ Linha+03, 0 PSay PADC(UPPER(XDESCR4),80)
@ Linha+04, 0 PSay PADC(UPPER(XDESCR5),80)
@ Linha+05, 0 PSay PADC(UPPER(XDESCR6),80)
@ Linha+06, 0 PSay PADC(UPPER(XDESCR7),80)
@ Linha+07, 0 PSay PADC(UPPER(XDESCR8),80)
@ Linha+08, 0 PSay PADC(UPPER(XDESCR9),80)
@ Linha+09, 0 PSay PADC(UPPER(XDESCR10),80)
@ Linha+10, 0 PSay PADC(UPPER(XDESCR11),80)
@ Linha+11, 0 PSay PADC(UPPER(XDESCR12),80)
@ Linha+12, 0 PSay PADC(UPPER(XDESCR13),80)
@ Linha+13, 0 PSay PADC(UPPER(XDESCR14),80)
//@ Linha+14, 0 PSay PADC(UPPER(XDESCR15),55)

/*If xFR2 > 0 
  xVl := 0    
  xVl := (xFR2 * 17)/ 100
  @ Linha+13, 0 PSay "Valor do Frete "
  @ Linha+13,35 PSay xFR2   Picture "@E@Z 999,999.99"
  @ Linha+14, 0 PSay "Icms Frete"
  @ Linha+14,35 PSay xVl   Picture "@E@Z 999,999.99"
Else
  @ Linha+13, 0 PSay PADC(UPPER(XDESCR14),55)
  @ Linha+14, 0 PSay PADC(UPPER(XDESCR15),55)
Endif*/

Linha := Linha + 19

Return

