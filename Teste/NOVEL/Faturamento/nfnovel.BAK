▒▒│Descrićģo │ Impressao de Linhas de Detalhe da Nota Fiscal              │▒▒
▒▒├──────────┼────────────────────────────────────────────────────────────┤▒▒
▒▒│Uso       │ EXCLUSIVO                                                  │▒▒
▒▒└──────────┴────────────────────────────────────────────────────────────┘▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
/*/

Static Function IMPDET
nVtot:=0
nTamDet       := 11            // Tamanho da Area de Detalhe
//nTamDet       := Len(xCOD_PRON)
nLinIniImpDet := Linha         // Linha de Inicio de Impressao de Detalhe
Linha         := nLinIniImpDet

I := 1
J := 1
Q := 0

xB_ICMS_SOL := 0          // Base  do ICMS Solidario
xV_ICMS_SOL := 0          // Valor do ICMS Solidario

If Empty(xVOLUME[1]).and.EMPTY(xVOLUME[2]).and.EMPTY(xVOLUME[3]).and.EMPTY(xVOLUME[4])
	xESP_VOL   :={}
	xQTD_VOL   :={}
EndIf

// Compactacao Para Impressao do Detalhe e Totais da Nota

@ linha-1, 000 Psay Chr(15)

//For I:=1 to Len(xCOD_PRO)//nTamDet
//For I:=1 to Len(nTamDet)
For I:=1 to 11
	 If I<=Len(xCOD_PRO)
		 If Empty(xVOLUME[1]).and.EMPTY(xVOLUME[2]).and.EMPTY(xVOLUME[3]).and.EMPTY(xVOLUME[4])
			 Posicao:=Ascan(xESP_VOL  ,xTPEMB[I])
			 If xQTDEMB[I] > xQTD_PRO[I]
				 xQTDEMB[I]:=xQTD_PRO[I]
			 EndIf
			 If xQTDEMB[I]==0
				 xQTDEMB[I]:=1
			 EndIf
			 TOTVOL :=INT(xQTD_PRO[I]/xQTDEMB[I])
			 If Posicao == 0
				 AADD(xESP_VOL   ,xTPEMB[I])
				 AADD(xQTD_VOL   ,0)
				 Posicao:=LEN(xESP_VOL)
			 EndIf
			 xQTD_VOL[Posicao]:=xQTD_VOL[Posicao]+TOTVOL
   
			 If xQTDEMB[I] <> 0  
				 If xQTD_PRO[I]/xQTDEMB[I] <> INT(xQTD_PRO[I]/xQTDEMB[I])
					 xQTD_VOL[Posicao]:=xQTD_VOL[Posicao] + 1
				 EndIf
			 EndIF  
		 Else
			 xQTD_VOL[1] := xVOLUME[1]
			 xQTD_VOL[2] := xVOLUME[2]
			 xQTD_VOL[3] := xVOLUME[3]
			 xQTD_VOL[4] := xVOLUME[4]
			 xESP_VOL[1] := xESPECIE[1]
			 xESP_VOL[2] := xESPECIE[2]
			 xESP_VOL[3] := xESPECIE[3]
			 xESP_VOL[4] := xESPECIE[4]
		 EndIf    
 	     IF xTipoNf <> "I" //SE FOR DIFERENTE DE COMPLEMENTO DE ICMS IMPRIME DETALHE                                                                              
//          @ Linha, 000 PSay xCOD_PRO[I]                                   
            @ Linha, 000 PSay xCOD_PRON[I]                                   

            DbselectArea("SC6")
            DbsetOrder(2)
            Dbseek(xFilial()+xCOD_PRON[I]+xPED_VEND[I])
			If Found()
               IF xSERVIC == "S"
			      @ Linha, 14 PSay Alltrim(SC6->C6_DESCRI)+" - S"
  		       ELSE
			      @ Linha, 14 PSay Alltrim(SC6->C6_DESCRI)
		       ENDIF					       
			Else
               IF xSERVIC == "S"
			      @ Linha, 14 PSay xDESC_PRO[I]+" - S"
  		       ELSE
			      @ Linha, 14 PSay xDESC_PRO[I]
		       ENDIF					
			Endif
				  
            @ Linha, 055 PSay xCOD_CPI[I]
//          @ Linha, 063 PSay xCOD_FIS[I]
		    @ Linha, 069 PSay xCOD_TRIB[I]+xCODT[I]
   		    @ Linha, 074 PSay xUNID_PRO[I]
		    @ Linha, 077 PSay xQTD_PRO[I]               Picture "@E@Z 9999999.99"
	   	    @ Linha, 088 PSay xPRE_UNI[I]               Picture "@E@Z 999,999.9999"
		    @ Linha, 110 PSay xVAL_MERC[I]              Picture "@E@Z 99,999,999.99"
	 
		    nValTot:=nValTot+xVAL_MERC[I]
		 
		    If xMICRO == "S" .and. xCOND_PAG<>'039'
			   xICMS[I] := 7
		    Endif
            @ Linha, 125 PSay xICMS[I]                  Picture "@E 99"
		    
		    
		    
		    If xTipoNf <> "P"   
		       @ Linha, 128 PSay xIPI[I]                   Picture "@E 99"
		       @ Linha, 135 PSay xVAL_IPI[I]               Picture "@E@Z 999,999.99"
		    EndIf
 		    J:=J+1
		    // Calculo do ICMS solidario
		    If xTIPO_CLI=="S"
			   xB_ICMS_SOL:=xB_ICMS_SOL+xVAL_MERC[I]*xLUCRO[I]/100
			   xV_ICMS_SOL:=xV_ICMS_SOL+xVAL_MERC[I]*xLUCRO[I]/100*xICMS[I]/100		 
     	    Endif     	 
     	 Endif 
         linha++
	 Endif         
	 //_L()
Next      

z := Len(xESP_VOL)

Do While z<=4
	z:=z+1
	AADD(xESP_VOL, " ")
	AADD(xQTD_VOL, 0)
End

//Linha := Linha - Q

Return

/*/                                     
