/*/

//┌─────────────────────┐
//│ Inicio da Funcao    │
//└─────────────────────┘

Static Function DUPLIC

If xDUPLICATAS==.T. .and. BB<=Len(xVALOR_DUP)

	If Len(xVENC_DUP) < 2
		xPARC_DUP[BB] :="-U"
	EndIf

	@ Linha, nCol     PSay xNUM_DUPLIC + xPARC_DUP[BB]
	@ Linha, nCol+19  PSay xVENC_DUP[BB]
	@ Linha, nCol+37  PSay xVALOR_DUP[BB] Picture ("@E 999,999.99")
    
Endif

BB:=BB+1

Return

