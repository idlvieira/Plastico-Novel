#include "rwmake.ch"        

User Function PEGAREQ()


_cAlias := ALIAS( )
_cOrd   := INDEXORD( )
 nReg   := RECNO( )
 
SetPrvt("xCOD")
         
//┌─────────────────────────────────────────────────────────────────────┐
//│ Pega a DescrińŃo da RequisińŃo para o historico                     │
//│                                                                     │
//└─────────────────────────────────────────────────────────────────────┘
       
xcod  := SB1->B1_COD
MHIST := SPACE(40)
DbSelectArea("SB1")
DbSetOrder(1)
DbSeek(xFilial()+xCOD) // Posiciona no PRODUTO. 
Mdesc := alltrim(B1_DESC)
   
DbSelectArea("SD3")
Mcp  := D3_NUMSA
Mcpi := D3_ITEMSA
Mqtd := alltrim(STR(D3_QUANT,16,6))
Musa := alltrim(D3_USUARIO)

DbSelectArea("SCP")
DbSetOrder(1)
DbSeek(xFilial()+xcp+xcpi) // Posiciona no PRODUTO.  
mobs := alltrim(cp_obs)

MHIST = mqtd+" "+mdesc+" "+"Solic Por: "+musa+" "+mobs

DBSELECTAREA( _cAlias )
DBSETORDER( _cOrd )
DBGOTO( nReg )

Return( MHIST ) 
                         
