/*/
User Function BUSCAARQ()
Local MvPar   		:=	""
Local MvParDef		:=	""
Local cTitulo		:=	"Selecione o caminho do arquivo desejado"

Private _cType 		:= ""

_cType := "*.CSV | *.CSV"
_cFile := cGetFile(_cType, OemToAnsi("Selecione o arquivo (*.CSV)"))

If Empty(_cFile)
	Return
EndIf

nHdl := fopen(_cFile,0)
_nTot:= fSeek(nHdl,0,2)
fClose(nHdl)
MV_PAR02 := ALLTRIM(_cFile)
Return()

