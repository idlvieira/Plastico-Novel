/*/

Static Function GeraTexto(cTxt,cNum)
Local cDirFil 	:= 	"\SPOOL\" + cNum + ".TXT"

if 	nHanErr	==	0
	nHanErr	:=	fCreate(cDirFil)
	if 	nHanErr	<=	0
		Alert("Nao foi possivel gerar o arquivo " + cDirFil + " ! Verifique....")
	endif
endif

if 	nHanErr	>	0
	fWrite( nHanErr , cTxt + Chr(13) + Chr(10) , Len(cTxt) + 2 )
endif

Return

