*/
User Function EMAPRDES()

	Local oHtml
	Local oEmail
	Local cServidor	:=	GetMv("MV_RELSERV")
	Local cConta	:=	GetMv("MV_RELACNT")
	Local cPassWord	:=	GetMv("MV_RELPSW")
	Local cAutentic	:=	GetMv("MV_RELAUTH")
	Local cAnexo    := '' 	
	Local cTitulo 	:= ""
	Local aCorpo  	:= {}
	Local aRodape 	:= {} 
	Local cAssunto  := "Foi aprovado o desconto do Orчamento de numero "+SUA->UA_NUM
	Local cPara 	:= Posicione("SU7",1,xFilial("SU7")+SUA->UA_OPERADO,"U7_MAIL") //"fernando.amorim@qsdobrasil.com"
	Local cCC		:= Posicione("SA3",1,xFilial("SA3")+SUA->UA_VEND,"A3_EMAIL")
	Local cCCo		:= ""  
	Local cRemet 	:= GetMv("MV_RELACNT")
	
    //cRemet := EMAILUSR()
	
	
	DbSelectarea("SF2")  
	

	
		
		aAdd(aCorpo, 'O Desconto do Oчamento abaixo:')
		aAdd(aCorpo, '')
		aAdd(aCorpo, 'Numero '+SUA->UA_NUM )
		aAdd(aCorpo, '')
		aAdd(aCorpo, 'Foi aprovado pela analise de Desconto. ')
		aAdd(aRodape, '')
		aAdd(aRodape, 'Obrigado')
	
			
	oHtml:= CorpoEmail():New(cTitulo, aCorpo, aRodape)	
	oHtml:GeraHtml()	
	&&Enviando E-mail		
	oEmail:=ConEmail():New(cServidor, cConta, cPassWord, ,cAutentic, )
	oEmail:EmailUsr()
	oEmail:Conectar()    
	If oEmail:Enviar(AllTrim(cRemet), AllTrim(cPara), AllTrim(cCC), AllTrim(cCCO), AllTrim(cAssunto), oHtml:cHtml, cAnexo)
		lRetorno	:=	.t.
		Aviso(FunDesc(),"E-mail enviado com SUCESSO.",{"OK"})
	EndIf
	oEmail:Desconec()    
	

	
Return      


