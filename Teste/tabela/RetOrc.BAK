User Function RetOrc(oProcess)


Local cCod1 	:= oProcess:oHtml:RetByName('NUM_SC')
Local cNum		:= oProcess:oHtml:RetByName('NUM_SC')
MsgAlert("teste")
If cResult == "LIB"
	SUA->(DbSetorder(1))
	if SUA->(DbSeek(xFilial("SUA")+cNum)) 
			RecLock("SUA", .f.)
			SUA->UA_STATU2 := "LIB"
			SUA->(MsUnLock())
   			U_EMAPRDES()
    Endif
Else
	SUA->(DbSetorder(1))
	if SUA->(DbSeek(xFilial("SUA")+cNum)) 
			RecLock("SUA", .f.)
			SUA->UA_STATU2 := "REJ"
			SUA->(MsUnLock())
			U_EMARJDES
    Endif



Endif    



Return  


